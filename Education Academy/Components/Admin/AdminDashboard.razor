@page "/admin/dashboard"
@using EducationAcademy.Models
@using Microsoft.EntityFrameworkCore
@attribute [Authorize(Roles = "Admin")]
@inject IDbContextFactory<AcademyDbContext> DbFactory
@*صفحة جانبية بتعرض الطلاب*@
<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-8">
    <MudGrid>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4">
                <MudText Typo="Typo.subtitle1">إجمالي الطلاب</MudText>
                <MudText Typo="Typo.h4">@totalStudents</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudTable Items="@students" Filter="new Func<ApplicationUser, bool>(FilterFunc)">
        <HeaderContent>
            <MudTh>الاسم</MudTh>
            <MudTh>الايميل</MudTh>
            <MudTh>المستوى الحالي</MudTh>
            <MudTh>النقاط (XP)</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.FullName</MudTd>
            <MudTd>@context.Email</MudTd>
            <MudTd>@context.CurrentLevel</MudTd>
            <MudTd>@context.XP</MudTd>
        </RowTemplate>
    </MudTable>

    <MudTable Items="@students" Context="student">
        <HeaderContent>
            <MudTh>الاسم</MudTh>
            <MudTh>الايميل</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@student.FullName</MudTd>
            <MudTd>@student.Email</MudTd>
        </RowTemplate>
    </MudTable>

</MudContainer>

@code {
    private List<ApplicationUser> students = new();
    private int totalStudents = 0;

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        students = await context.Users.Where(u => !u.IsAdmin).ToListAsync();
        totalStudents = students.Count;
    }

    private bool FilterFunc(ApplicationUser element) => string.IsNullOrWhiteSpace(searchString) ||
        element.FullName.Contains(searchString, StringComparison.OrdinalIgnoreCase);
    private string searchString = "";
}