@page "/admin/upload"
@using EducationAcademy.Models
@using EducationAcademy.Services
@attribute [Authorize(Roles = "Admin")]
@inject EncryptionService Encryptor
@inject AcademyDbContext DbContext
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<AcademyDbContext> DbFactory
@*صفحة جانبية مش مهمة لرفع الداتا*@
<MudPaper Class="pa-8 mt-4 shadow-lg" Style="max-width: 600px; margin: auto;">
    <MudText Typo="Typo.h5">رفع وتشفير مادة تعليمية</MudText>
    
    <MudSelect T="int" Label="المستوى المستهدف" @bind-Value="targetLevel">
        <MudSelectItem Value="1">المستوى الأول</MudSelectItem>
        <MudSelectItem Value="2">المستوى الثاني</MudSelectItem>
        <MudSelectItem Value="3">المستوى الثالث</MudSelectItem>
        <MudSelectItem Value="4">المستوى الرابع</MudSelectItem>
    </MudSelect>


    @if (isUploading) { <MudProgressLinear Indeterminate="true" /> }
</MudPaper>

@code {
    private int targetLevel = 1;
    private bool isUploading = false;

    private async Task HandleFileUpload(InputFileChangeEventArgs e)
    {
        isUploading = true;
        var file = e.File;
        
        using var stream = file.OpenReadStream(maxAllowedSize: 15 * 1024 * 1024);
        var encryptedBytes = await Encryptor.EncryptFile(stream);

        var fileName = $"{Guid.NewGuid()}.enc";
        var path = Path.Combine("wwwroot", "materials", fileName);
        
        await File.WriteAllBytesAsync(path, encryptedBytes);

        var material = new Material {
            Title = file.Name,
            EncryptedFilePath = fileName,
            LevelId = targetLevel
        };

        DbContext.Materials.Add(material);
        await DbContext.SaveChangesAsync();
        
        isUploading = false;
    }
    // تعريف القائمة التي سيستخدمها الجدول
    private List<ApplicationUser> students = new List<ApplicationUser>();
    
    private int totalStudents = 0;
    private string searchString = "";

    // جلب البيانات من قاعدة البيانات عند تحميل الصفحة
    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        
        // جلب المستخدمين الذين ليسوا أدمن
        students = await context.Users
                                .Where(u => !u.IsAdmin)
                                .ToListAsync();
                                
        totalStudents = students.Count;
    }

    // دالة الفلترة 
    private bool FilterFunc(ApplicationUser element)
    {
        if (string.IsNullOrWhiteSpace(searchString)) return true;
        if (element.FullName.Contains(searchString, StringComparison.OrdinalIgnoreCase)) return true;
        if (element.Email.Contains(searchString, StringComparison.OrdinalIgnoreCase)) return true;
        return false;
    }

}