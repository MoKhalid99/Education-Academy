@page "/games/bug-invasion"
@inject IJSRuntime JS

<div class="game-3d-wrapper">
    <div class="quiz-overlay">
        @if (!string.IsNullOrEmpty(currentQuestion))
        {
            <div class="glass-card">
                <h5>@currentQuestion</h5>
                <div class="options-grid">
                    @foreach (var opt in options)
                    {
                        <button class="opt-btn" @onclick="() => VerifyAnswer(opt)">@opt</button>
                    }
                </div>
            </div>
        }
    </div>

    <div id="threejs-container" style="width: 100%; height: 80vh;"></div>
</div>

@code {
    private string currentQuestion = "Correct way to inherit in C#?";
    private string[] options = { ": Base", "extends Base", "implements Base" };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // بدء محرك الـ 3D
            await JS.InvokeVoidAsync("initTowerDefense", "threejs-container");
        }
    }

    private async Task VerifyAnswer(string ans)
    {
        if (ans == ": Base")
        {
            // أمر لـ Three.js بإطلاق الليزر
            await JS.InvokeVoidAsync("fireLaser");
            LoadNextQuestion();
        }
    }

    private void LoadNextQuestion() { /* منطق جلب سؤال جديد من JSON */ }
}