@page "/game/fgmadd"
@using System.Text.Json
@using System.IO
@using FG1MAdd
@implements IDisposable
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment Env
@inject IJSRuntime JS

<style>
    body, html {
        margin: 0;
        padding: 0;
        overflow: hidden;
        background: #050507;
    }

    .game-container {
        width: 100vw;
        height: 100vh;
        position: relative;
        overflow: hidden;
        font-family: 'Segoe UI', Tahoma, sans-serif;
        color: white;
        outline: none;
    }

    /* شاشة الكود  */
    .code-overlay {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 700px;
        background: rgba(15, 15, 25, 0.96);
        padding: 30px;
        border: 2px solid #00d2ff;
        border-radius: 20px;
        z-index: 1000;
        box-shadow: 0 0 60px rgba(0, 210, 255, 0.3);
        backdrop-filter: blur(10px);
    }

        .code-overlay textarea {
            width: 100%;
            height: 180px;
            background: #0a0a1a;
            color: #4ecca3;
            border: 1px solid #333;
            padding: 15px;
            font-family: 'Consolas', 'Courier New', monospace;
            font-size: 1.1rem;
            border-radius: 10px;
            margin: 15px 0;
            resize: none;
        }

    /* Stick-man */
    .fighter {
        position: absolute;
        width: 80px;
        height: 150px;
        bottom: 15vh;
        z-index: 20;
        transition: opacity 0.3s;
    }

    .head {
        width: 32px;
        height: 32px;
        border: 3px solid white;
        border-radius: 50%;
        position: absolute;
        top: 0;
        left: 24px;
    }

    .torso {
        width: 4px;
        height: 60px;
        background: white;
        position: absolute;
        top: 35px;
        left: 38px;
        border-radius: 2px;
    }

    .arm-l, .arm-r, .leg-l, .leg-r {
        width: 4px;
        height: 45px;
        background: white;
        position: absolute;
        transform-origin: top center;
        border-radius: 2px;
    }

    .arm-l {
        top: 40px;
        left: 38px;
        transform: rotate(35deg);
    }

    .arm-r {
        top: 40px;
        left: 38px;
        transform: rotate(-35deg);
    }

    .leg-l {
        top: 95px;
        left: 38px;
        transform: rotate(15deg);
    }

    .leg-r {
        top: 95px;
        left: 38px;
        transform: rotate(-15deg);
    }

    /* ألوان اللاعب */
    .player .head, .player .torso,
    .player .arm-l, .player .arm-r,
    .player .leg-l, .player .leg-r {
        background: #00d2ff;
        border-color: #00d2ff;
        box-shadow: 0 0 15px #00d2ff;
    }

    /* ألوان العدو أسود */
    .enemy .head, .enemy .torso,
    .enemy .arm-l, .enemy .arm-r,
    .enemy .leg-l, .enemy .leg-r {
        background: #111;
        border-color: #444;
        box-shadow: 0 0 15px rgba(255, 255, 255, 0.2);
    }

    /* WALK — خطوات واقعية */
    .walking .leg-l {
        animation: step-l 0.35s infinite;
        transform-origin: top center;
    }

    .walking .leg-r {
        animation: step-r 0.35s infinite;
        transform-origin: top center;
    }

    @@keyframes step-l {
        0% {
            transform: rotate(-40deg) translateY(0);
        }

        25% {
            transform: rotate(-40deg) translateY(-4px);
        }

        50% {
            transform: rotate(40deg) translateY(0);
        }

        75% {
            transform: rotate(40deg) translateY(-4px);
        }

        100% {
            transform: rotate(-40deg) translateY(0);
        }
    }

    @@keyframes step-r {
        0% {
            transform: rotate(40deg) translateY(0);
        }

        25% {
            transform: rotate(40deg) translateY(-4px);
        }

        50% {
            transform: rotate(-40deg) translateY(0);
        }

        75% {
            transform: rotate(-40deg) translateY(-4px);
        }

        100% {
            transform: rotate(40deg) translateY(0);
        }
    }

    .walking .torso {
        animation: body-bob 0.35s infinite ease-in-out;
    }

    @@keyframes body-bob {
        0%, 100% {
            transform: translateY(0);
        }

        50% {
            transform: translateY(-5px);
        }
    }

    .walking .arm-l {
        animation: arm-swing-l 0.35s infinite;
        transform-origin: top center;
    }

    .walking .arm-r {
        animation: arm-swing-r 0.35s infinite;
        transform-origin: top center;
    }

    @@keyframes arm-swing-l {
        0%, 100% {
            transform: rotate(20deg);
        }

        50% {
            transform: rotate(-20deg);
        }
    }

    @@keyframes arm-swing-r {
        0%, 100% {
            transform: rotate(-20deg);
        }

        50% {
            transform: rotate(20deg);
        }
    }

    /* ATTACK ANIMATIONS */
    .blue-beam-attack .arm-r {
        animation: blue-beam-arm 0.4s ease-out forwards;
        transform-origin: top center;
    }

    @@keyframes blue-beam-arm {
        0% {
            transform: rotate(-35deg);
        }

        30% {
            transform: rotate(-130deg) scaleX(1.6);
        }

        70% {
            transform: rotate(-130deg) scaleX(1.6);
        }

        100% {
            transform: rotate(-35deg);
        }
    }

    .logic-fall-attack .arm-l {
        animation: logic-chop 0.4s ease-in-out forwards;
        transform-origin: top center;
    }

    @@keyframes logic-chop {
        0% {
            transform: rotate(35deg);
        }

        40% {
            transform: rotate(-160deg);
        }

        100% {
            transform: rotate(35deg);
        }
    }

    .vortex-attack {
        animation: vortex-spin-attack 0.6s ease-in-out;
    }

    @@keyframes vortex-spin-attack {
        0% {
            transform: rotate(0deg) scaleX(var(--flip,1));
        }

        50% {
            transform: rotate(360deg) scaleX(var(--flip,1));
        }

        100% {
            transform: rotate(720deg) scaleX(var(--flip,1));
        }
    }

    .vortex-attack .arm-l, .vortex-attack .arm-r {
        animation: vortex-arms 0.6s ease-in-out;
    }

    @@keyframes vortex-arms {
        0%, 100% {
            transform: rotate(35deg);
        }

        50% {
            transform: rotate(180deg);
        }
    }

    .ladder-fall-attack .leg-r {
        animation: ladder-kick 0.45s ease-out forwards;
        transform-origin: top center;
    }

    @@keyframes ladder-kick {
        0% {
            transform: rotate(-15deg);
        }

        40% {
            transform: rotate(-100deg) scaleY(1.4);
        }

        100% {
            transform: rotate(-15deg);
        }
    }

    .ultimate-combo-attack {
        animation: ultimate-flash 0.8s ease-in-out;
    }

    @@keyframes ultimate-flash {
        0%, 100% {
            filter: brightness(1);
        }

        25% {
            filter: brightness(3) saturate(2);
        }

        50% {
            filter: brightness(1);
        }

        75% {
            filter: brightness(3) saturate(2);
        }
    }

    .ultimate-combo-attack .arm-l {
        animation: combo-arm-l 0.8s ease-in-out;
        transform-origin: top center;
    }

    .ultimate-combo-attack .arm-r {
        animation: combo-arm-r 0.8s ease-in-out;
        transform-origin: top center;
    }

    @@keyframes combo-arm-l {
        0% {
            transform: rotate(35deg);
        }

        25% {
            transform: rotate(-150deg);
        }

        50% {
            transform: rotate(35deg);
        }

        75% {
            transform: rotate(-150deg);
        }

        100% {
            transform: rotate(35deg);
        }
    }

    @@keyframes combo-arm-r {
        0% {
            transform: rotate(-35deg);
        }

        25% {
            transform: rotate(150deg);
        }

        50% {
            transform: rotate(-35deg);
        }

        75% {
            transform: rotate(150deg);
        }

        100% {
            transform: rotate(-35deg);
        }
    }

    /* ENEMY SPECIAL ATTACKS */

    .enemy-special-python {
        animation: python-venom 1.2s ease-in-out;
    }

    @@keyframes python-venom {
        0%, 100% {
            transform: translateY(0) scaleX(var(--flip,1));
        }

        20% {
            transform: translateY(-18px) scaleX(var(--flip,1));
        }

        40% {
            transform: translateY(8px) scaleX(var(--flip,1));
        }

        60% {
            transform: translateY(-12px) scaleX(var(--flip,1));
        }

        80% {
            transform: translateY(5px) scaleX(var(--flip,1));
        }
    }

    .enemy-special-python .torso {
        animation: python-torso 1.2s ease-in-out;
    }

    @@keyframes python-torso {
        0%, 100% {
            background: #ff4757;
            box-shadow: 0 0 15px #ff4757;
        }

        50% {
            background: #7dff57;
            box-shadow: 0 0 40px #7dff57;
        }
    }

    /* C# Shield */
    .enemy-special-cs {
        animation: cs-shield-pulse 0.8s infinite alternate;
    }

    @@keyframes cs-shield-pulse {
        from {
            filter: drop-shadow(0 0 12px #512bd4) brightness(1);
        }

        to {
            filter: drop-shadow(0 0 30px #00d2ff) brightness(1.5);
        }
    }

    .enemy-special-cs::before {
        content: '';
        position: absolute;
        inset: -18px -20px;
        border: 3px solid rgba(81,43,212,0.8);
        border-radius: 50% 50% 40% 40%;
        background: rgba(81,43,212,0.15);
        animation: shield-dome-rotate 1s linear infinite;
    }

    @@keyframes shield-dome-rotate {
        to {
            transform: rotate(360deg);
        }
    }

    /* DODGE & HIT REACTION */
    .dodging {
        animation: dodge-sidestep 0.5s ease-out forwards;
    }

    @@keyframes dodge-sidestep {
        0% {
            opacity: 1;
            filter: blur(0px) scaleX(1);
            transform: translateX(0) scaleX(1);
        }

        30% {
            opacity: 0.15;
            filter: blur(8px);
            transform: translateX(60px) scaleX(1);
        }

        60% {
            opacity: 0.15;
            filter: blur(8px);
            transform: translateX(60px) scaleX(1);
        }

        100% {
            opacity: 1;
            filter: blur(0px);
            transform: translateX(0) scaleX(1);
        }
    }

    .hit-reaction {
        animation: shake-char 0.22s;
    }

    @@keyframes shake-char {
        0%, 100% {
            transform: translateX(0);
        }

        25% {
            transform: translateX(-10px);
        }

        75% {
            transform: translateX(10px);
        }
    }

    .face-left {
        transform: scaleX(1);
    }

    .face-right {
        transform: scaleX(-1);
    }

    /* VISUAL EFFECTS */
    .blue-beam {
        position: absolute;
        height: 12px;
        background: linear-gradient(90deg, #00d2ff, transparent);
        box-shadow: 0 0 25px #00d2ff;
        z-index: 5;
        animation: beam-flow 0.6s forwards;
    }

    @@keyframes beam-flow {
        from {
            width: 0;
            opacity: 1;
        }

        to {
            width: 100%;
            opacity: 0;
        }
    }

    /* ليزر C++ الأحمر */
    .red-laser {
        position: absolute;
        height: 10px;
        background: linear-gradient(270deg, #ff0000, #ff0000 80%, transparent);
        box-shadow: 0 0 20px #ff0000;
        z-index: 5;
        top: 78vh;
        animation: red-laser-fire 0.4s ease-out forwards;
        transform-origin: right center; /* ينطلق من العدو باتجاه اللاعب */
    }

    @@keyframes red-laser-fire {
        0% {
            transform: scaleX(0);
            opacity: 1;
        }

        50% {
            transform: scaleX(1);
            opacity: 1;
        }

        100% {
            transform: scaleX(1);
            opacity: 0;
        }
    }

    .poison-cloud {
        position: absolute;
        bottom: 15vh;
        width: 100vw;
        height: 30vh;
        background: radial-gradient(ellipse at center, rgba(125,255,87,0.2) 0%, transparent 70%);
        animation: poison-fade 5s forwards;
        z-index: 3;
        pointer-events: none;
    }

    @@keyframes poison-fade {
        0% {
            opacity: 1;
        }

        100% {
            opacity: 0;
        }
    }

    /* HUD */
    .stats-hud {
        position: absolute;
        top: 40px;
        width: 100%;
        display: flex;
        justify-content: space-around;
        z-index: 100;
    }

    .hp-container {
        width: 350px;
        height: 30px;
        background: rgba(0,0,0,0.6);
        border: 2px solid #444;
        border-radius: 15px;
        overflow: hidden;
        position: relative;
    }

    .hp-bar {
        height: 100%;
        transition: width 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

    .hp-text {
        position: absolute;
        width: 100%;
        text-align: center;
        font-weight: bold;
        line-height: 30px;
        font-size: 0.9rem;
    }

    .poison-bar {
        position: absolute;
        bottom: 2px;
        left: 0;
        height: 4px;
        background: #7dff57;
        border-radius: 2px;
        transition: width 1s linear;
    }

    .ground {
        position: absolute;
        bottom: 15vh;
        width: 100%;
        height: 5px;
        background: #222;
    }

    .status-label {
        position: absolute;
        top: 90px;
        width: 100%;
        text-align: center;
        font-size: 1.1rem;
        color: #ffd700;
        text-shadow: 0 0 10px #ffd700;
        z-index: 101;
        min-height: 28px;
    }

    .enemy-punch .arm-l {
        animation: enemy-punch-anim 0.3s ease-in-out;
    }

    @@keyframes enemy-punch-anim {
        0% {
            transform: rotate(35deg);
        }

        50% {
            transform: rotate(-90deg) scaleX(1.5);
        }

        100% {
            transform: rotate(35deg);
        }
    }

    .bg-cpp {
        background: linear-gradient(135deg, #001f3f, #00d2ff) !important;
    }

    .bg-python {
        background: linear-gradient(135deg, #ffd700, #0000) !important;
    }

    .bg-cs {
        background: linear-gradient(135deg, #2b0b3d, #512bd4) !important;
    }
</style>

<div class="game-container @GetBackgroundClass()" @onkeydown="HandleKeyDown" @onkeyup="HandleKeyUp" tabindex="0">
    @if (gameState == "MENU")
    {
        <div class="menu" style="display:flex; flex-direction:column; align-items:center; justify-content:center; height:100%;">
            <h1 style="font-size: 5rem; color: #00d2ff; text-shadow: 0 0 20px #00d2ff;">ROGUELIKE CODER</h1>
            <div style="display:flex; gap:20px;">
                @foreach (var level in allLevels)
                {
                    <button class="lang-btn" style="background:@level.Color; padding:20px 40px; border:none; border-radius:10px; color:white; cursor:pointer; font-size:1.2rem; font-weight:bold;"
                            @onclick="() => SelectLanguage(level)">
                        @level.Language
                    </button>
                }
            </div>
        </div>
    }
    else if (gameState == "GAMEOVER")
    {
        <div class="menu" style="display:flex; flex-direction:column; align-items:center; justify-content:center; height:100%;">
            <h1 style="font-size: 6rem; color: #ff4757; text-shadow: 0 0 20px #ff4757; margin-bottom: 20px;">GAME OVER</h1>
            <button class="lang-btn" style="background:#555; padding:20px 40px; border:none; border-radius:10px; color:white; cursor:pointer; font-size:1.2rem;"
                    @onclick='() => gameState = "MENU"'>
                العودة للقائمة الرئيسية
            </button>
        </div>
    }
    else
    {
        <div class="arena">
            @if (activeEffect == "BlueBeam")
            {
                <div class="blue-beam" style="left: @(player.X + 5)vw; top: 78vh;"></div>
            }
            @if (showRedLaser)
            {
                <div class="red-laser" style="left: @(player.X + 5)vw; width: @(enemy.X - player.X)vw;"></div>
            }
            @if (showPoisonCloud)
            {
                <div class="poison-cloud"></div>
            }

            <div class="stats-hud">
                <div style="position:relative;">
                    <div class="hp-container">
                        <div class="hp-bar" style="width: @(Math.Max(0, player.HP))%; background: #00d2ff;"></div>
                        <div class="hp-text">PLAYER HP: @((int)Math.Max(0, player.HP))%</div>
                    </div>
                    @if (poisonSecondsLeft > 0)
                    {
                        <div class="poison-bar" style="width: @(poisonSecondsLeft * 20)%;"></div>
                    }
                </div>

                <div>
                    <div style="text-align:center; font-size:0.85rem; margin-bottom:4px; color:#aaa;">
                        @currentLevel.Language — Stage @(currentStageIndex + 1)/5
                    </div>
                    <div class="hp-container">
                        <div class="hp-bar" style="width: @(Math.Max(0, enemy.HP))%; background: #ff4757;"></div>
                        <div class="hp-text">ENEMY HP: @((int)Math.Max(0, enemy.HP))%</div>
                    </div>
                </div>
            </div>

            <div class="status-label">@statusMessage</div>

            @if (showCodeOverlay)
            {
                <div class="code-overlay">
                    <h2 style="color: #00d2ff;">المرحلة @currentStage.Level: @currentStage.MoveName</h2>
                    <p style="color: #aaa;">@currentStage.Description</p>
                    <textarea @bind="playerCode" @bind:event="oninput" placeholder="// اكتب الكود البرمجي هنا..."></textarea>
                    <div style="display:flex; justify-content: space-between;">
                        <button class="lang-btn" style="background:#4ecca3; width: 80%; border:none; border-radius:5px; cursor:pointer;" @onclick="SubmitCode">تفعيل القدرة (Enter)</button>
                        <button class="lang-btn" style="background:#555; width: 15%; border:none; border-radius:5px; cursor:pointer;" @onclick="() => showCodeOverlay = false">إغلاق (X)</button>
                    </div>
                </div>
            }

            @if (showTransitionOverlay && nextStageData != null)
            {
                <div class="code-overlay" style="text-align: center;">
                    <h2 style="color: #4ecca3;">أحسنت! تم القضاء على العدو </h2>
                    <h3 style="color: #00d2ff; margin-top: 20px;">المرحلة القادمة: @nextStageData.MoveName</h3>
                    <p style="color: #aaa;">تجهّز بالكومبو التالي لتهزمه (اكتب هذا الكود لاحقاً):</p>
                    <div style="background: #0a0a1a; padding: 15px; border-radius: 10px; color: #ff0055; font-family: monospace; font-size: 1.2rem; margin: 15px 0; border: 1px solid #333;">
                        @nextStageData.Output
                    </div>
                    <button class="lang-btn" style="background:#00d2ff; width: 100%; color:#000; padding: 10px; font-weight: bold; border:none; border-radius:5px; cursor:pointer;" @onclick="StartNextStage">بدء المرحلة (Enter)</button>
                </div>
            }

            <div class="ground"></div>

            <div class="fighter player @GetPlayerClasses()" style="left: @(player.X)vw">
                <div class="head"></div><div class="torso"></div>
                <div class="arm-l"></div><div class="arm-r"></div>
                <div class="leg-l"></div><div class="leg-r"></div>
            </div>

            <div class="fighter enemy @GetEnemyClasses()" style="left: @(enemy.X)vw">
                <div class="head"></div><div class="torso"></div>
                <div class="arm-l"></div><div class="arm-r"></div>
                <div class="leg-l"></div><div class="leg-r"></div>
            </div>
        </div>
    }
</div>

@code {
    // STATE 
    string gameState = "MENU";
    List<LevelData> allLevels = new();
    LevelData currentLevel = null!;
    StageData currentStage = null!;
    int currentStageIndex = 0;

    string playerCode = "";
    bool showCodeOverlay = false;
    bool showTransitionOverlay = false;
    StageData? nextStageData = null;

    string activeEffect = "";
    string statusMessage = "";
    Fighter player = new() { X = 15, HP = 100 };
    Fighter enemy = new() { X = 80, HP = 100 };

    bool isWalking = false;
    bool enemyIsWalking = false;
    int walkDir = 0;
    DateTime lastWalkStep = DateTime.MinValue;
    const double StepSize = 1.8;
    const int StepMs = 90;

    string playerAttackClass = "";
    string enemyAttackClass = "";
    string enemySpecialClass = "";
    bool isDodging = false;
    bool playerHit = false;
    bool enemyHit = false;
    string playerFlip = "face-left";
    string enemyFlip = "face-right";

    bool showPoisonCloud = false;
    bool showRedLaser = false;
    int poisonSecondsLeft = 0;

    System.Threading.Timer? poisonTimer;
    System.Threading.Timer? gameLoop;

    // توقيت الهجمات
    DateTime lastEnemySpecial = DateTime.Now.AddSeconds(-20);
    DateTime lastEnemyPunch = DateTime.Now; 

    string GetBackgroundClass() => currentLevel?.Language switch
    {
        "C++" => "bg-cpp",
        "Python" => "bg-python",
        "C#" => "bg-cs",
        _ => ""
    };

    protected override async Task OnInitializedAsync()
    {
        var filePath = Path.Combine(Env.WebRootPath, "data", "levels.json");
        if (File.Exists(filePath))
        {
            var json = await File.ReadAllTextAsync(filePath);
            allLevels = JsonSerializer.Deserialize<List<LevelData>>(json,
                new JsonSerializerOptions { PropertyNameCaseInsensitive = true }) ?? new();
        }
    }

    string GetPlayerClasses()
    {
        var parts = new List<string> { playerFlip };
        if (isDodging) parts.Add("dodging");
        if (isWalking) parts.Add("walking");
        if (playerAttackClass != "") parts.Add(playerAttackClass);
        if (playerHit) parts.Add("hit-reaction");
        return string.Join(" ", parts);
    }

    string GetEnemyClasses()
    {
        var parts = new List<string> { enemyFlip };
        if (enemyIsWalking) parts.Add("walking");
        if (enemyAttackClass != "") parts.Add(enemyAttackClass);
        if (enemySpecialClass != "") parts.Add(enemySpecialClass);
        if (enemyHit) parts.Add("hit-reaction");
        return string.Join(" ", parts);
    }

    async void SelectLanguage(LevelData lang)
    {
        currentLevel = lang;
        currentStageIndex = 0;
        player.HP = 100;
        LoadStage();
        gameState = "GAME";

        var file = lang.Language switch
        {
            "C++" => "cpp.mp3",
            "Python" => "py.mp3",
            "C#" => "cs.mp3",
            _ => ""
        };
        if (file != "") await JS.InvokeVoidAsync("playAudio", file);

        gameLoop?.Dispose();
        gameLoop = new System.Threading.Timer(OnGameTick, null, 0, 50);
        StateHasChanged();
    }

    void LoadStage()
    {
        currentStage = currentLevel.Stages[currentStageIndex];
        enemy.HP = currentStage.EnemyHP;
        player.X = 15;
        enemy.X = 80;
        lastEnemySpecial = DateTime.Now.AddSeconds(-18);
        showTransitionOverlay = false;
        showCodeOverlay = false;
    }

    // GAME LOOP
    void OnGameTick(object? state)
    {
        
        if (showCodeOverlay || showTransitionOverlay || gameState != "GAME") return;
        

        if (player.HP <= 0)
        {
            InvokeAsync(() => { gameState = "GAMEOVER"; StateHasChanged(); });
            return;
        }

        playerFlip = (player.X < enemy.X) ? "face-left" : "face-right";
        enemyFlip = (enemy.X < player.X) ? "face-left" : "face-right";

        // حركة اللاعب
        if (walkDir != 0 && !isDodging)
        {
            if ((DateTime.Now - lastWalkStep).TotalMilliseconds >= StepMs)
            {
                lastWalkStep = DateTime.Now;
                double nx = player.X + walkDir * StepSize;
                if (nx >= 2 && nx <= 90) player.X = nx;
            }
        }

        double dist = Math.Abs(player.X - enemy.X);
        double previousEnemyX = enemy.X;
        if (dist <= 8)
        {
            if ((DateTime.Now - lastEnemyPunch).TotalMilliseconds > 1500)
            {
                lastEnemyPunch = DateTime.Now;
                _ = EnemyNormalAttack();
            }
        }

        if (dist > 6 && !enemy.IsShielded && !showRedLaser)
        {
            double enemySpeed = 0.4;
            if (enemy.X < player.X) enemy.X += enemySpeed;
            else enemy.X -= enemySpeed;
        }

        enemyIsWalking = (enemy.X != previousEnemyX);

        if ((DateTime.Now - lastEnemySpecial).TotalSeconds > 7)
        {
            lastEnemySpecial = DateTime.Now;
            InvokeAsync(EnemySpecialMove);
        }

        InvokeAsync(StateHasChanged);
    }

    // ACTIONS
    async Task EnemyNormalAttack()
    {
        enemyAttackClass = "enemy-punch";
        await InvokeAsync(StateHasChanged);

        await Task.Delay(150);

        if (Math.Abs(player.X - enemy.X) < 9 && !isDodging)
        {
            player.HP -= 5;
            playerHit = true;
            await InvokeAsync(StateHasChanged);
            await Task.Delay(200);
            playerHit = false;
        }

        await Task.Delay(150);
        enemyAttackClass = "";
        await InvokeAsync(StateHasChanged);
    }

    async Task PlayerAttack()
    {
        if (playerAttackClass != "" || isDodging) return;
        playerAttackClass = GetAttackClass(currentStage.MoveName);
        int dur = currentStage.MoveName == "Ultimate Combo" ? 800 : 450;
        await Task.Delay(dur / 2);

        if (Math.Abs(player.X - enemy.X) < 7)
        {
            double dmg = currentStage.MoveName == "Ultimate Combo" ? 6 : 3;
            if (!enemy.IsShielded)
            {
                enemy.HP -= dmg;
                enemyHit = true;
                await Task.Delay(220);
                enemyHit = false;
                CheckEnemyDeath();
            }
            else
            {
                await SetStatus("Shield blocked the attack!");
            }
        }

        await Task.Delay(dur / 2);
        playerAttackClass = "";
    }

    void HandleKeyDown(KeyboardEventArgs e)
    {
        if (showTransitionOverlay)
        {
            if (e.Key == "Enter") StartNextStage();
            return;
        }
        if (showCodeOverlay)
        {
            if (e.Key == "Enter") SubmitCode();
            return;
        }
        if (e.Key == "ArrowRight") { walkDir = 1; isWalking = true; }
        if (e.Key == "ArrowLeft") { walkDir = -1; isWalking = true; }
        if (e.Key == "ArrowUp" || e.Key == "ArrowDown") { walkDir = 0; isWalking = false; }
        if (e.Key.ToLower() == "z") _ = PlayerAttack();
        if (e.Key.ToLower() == "x") { showCodeOverlay = !showCodeOverlay; walkDir = 0; isWalking = false; }
        if (e.Code == "Space") _ = DodgeAction();
    }

    void HandleKeyUp(KeyboardEventArgs e) { if (e.Key == "ArrowRight" || e.Key == "ArrowLeft") { walkDir = 0; isWalking = false; } }

    string GetAttackClass(string moveName) => moveName switch
    {
        "Blue Beam" => "blue-beam-attack",
        "Logic Fall" => "logic-fall-attack",
        "Vortex" => "vortex-attack",
        "Ladder Fall" => "ladder-fall-attack",
        "Ultimate Combo" => "ultimate-combo-attack",
        _ => "blue-beam-attack"
    };

    async Task EnemySpecialMove()
    {
        if (currentLevel.Language == "Python")
        {
            enemySpecialClass = "enemy-special-python";
            showPoisonCloud = true;
            await SetStatus("Python Venom! 2 HP/sec for 5 seconds!");
            poisonSecondsLeft = 5;
            await Task.Delay(1200);
            enemySpecialClass = "";
            poisonTimer?.Dispose();
            poisonTimer = new System.Threading.Timer(async _ =>
            {
                if (showCodeOverlay || showTransitionOverlay || gameState != "GAME") return;
                if (poisonSecondsLeft <= 0)
                {
                    poisonTimer?.Dispose();
                    showPoisonCloud = false;
                    await InvokeAsync(StateHasChanged);
                    return;
                }
                if (!isDodging) player.HP -= 2;
                poisonSecondsLeft--;
                await InvokeAsync(StateHasChanged);
            }, null, 1000, 1000);
        }
        else if (currentLevel.Language == "C++")
        {
            await SetStatus("C++ Laser Beam!");
            showRedLaser = true;
            await Task.Delay(200);
            if (!isDodging)
            {
                player.HP -= 15;
                playerHit = true;
                await InvokeAsync(StateHasChanged);
                await Task.Delay(200);
                playerHit = false;
            }
            else { await SetStatus(" Dodged Laser!"); }
            await Task.Delay(200);
            showRedLaser = false;
            await InvokeAsync(StateHasChanged);
        }
        else if (currentLevel.Language == "C#")
        {
            enemy.IsShielded = true;
            enemySpecialClass = "enemy-special-cs";
            await SetStatus(" C# Shield active for 5 seconds!");
            await Task.Delay(5000);
            enemy.IsShielded = false;
            enemySpecialClass = "";
            await SetStatus("Shield expired.");
        }
    }

    async Task DodgeAction()
    {
        if (isDodging) return;
        isDodging = true; isWalking = false;
        await Task.Delay(500);
        isDodging = false;
    }

    async void SubmitCode()
    {
        if (playerCode.Trim() == currentStage.Output)
        {
            activeEffect = "BlueBeam";
            double dmg = currentStage.Level == 5 ? 60 : 35;
            if (enemy.IsShielded) { dmg *= 0.3; await SetStatus(" Shield reduced code damage!"); }
            enemy.HP -= dmg;
            showCodeOverlay = false; playerCode = "";
            await Task.Delay(1000);
            activeEffect = "";
            CheckEnemyDeath();
        }
        else
        {
            player.HP -= 15; playerHit = true;
            await Task.Delay(300); playerHit = false;
            await SetStatus("Wrong answer! -15 HP");
        }
        StateHasChanged();
    }

    void CheckEnemyDeath()
    {
        if (enemy.HP <= 0)
        {
            if (currentStageIndex + 1 < currentLevel.Stages.Count)
            {
                nextStageData = currentLevel.Stages[currentStageIndex + 1];
                showTransitionOverlay = true;
            }
            else { _ = JS.InvokeVoidAsync("stopAudio"); gameState = "MENU"; }
        }
    }

    void StartNextStage() { currentStageIndex++; LoadStage(); }

    async Task SetStatus(string msg)
    {
        statusMessage = msg;
        await InvokeAsync(StateHasChanged);
        await Task.Delay(2500);
        if (statusMessage == msg) statusMessage = "";
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        gameLoop?.Dispose();
        poisonTimer?.Dispose();
    }
}