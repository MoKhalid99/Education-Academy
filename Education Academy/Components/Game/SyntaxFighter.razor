@page "/games/fighter"
@inject IJSRuntime JS

<div class="battle-arena">
    <div class="health-container">
        <div class="health-bar player-hb"><div class="fill" style="width:@playerHealth%"></div></div>
        <div class="vs-text">VS</div>
        <div class="health-bar enemy-hb"><div class="fill" style="width:@enemyHealth%"></div></div>
    </div>

    <div class="characters-stage">
        <img src="images/hero-idle.png" class="character player @playerAnimClass" />
        <img src="images/bug-boss.png" class="character enemy @enemyAnimClass" />
    </div>

    <div class="code-box">
        @if (!gameOver)
        {
            <p class="question">ما هو التصحيح لهذا الكود؟</p>
            <code>@currentCodeTask</code>
            <div class="options">
                @foreach (var option in currentOptions)
                {
                    <button @onclick="() => CheckAnswer(option)">@option</button>
                }
            </div>
            <div class="timer-bar"><div class="timer-fill" style="width:@(timerValue)%"></div></div>
        }
        else
        {
            <h2 class="result-text">@(playerHealth > 0 ? "لقد سحقت الخطأ! +100 XP" : "هزمك الـ Bug.. حاول مجدداً")</h2>
            <button class="btn-retry" @onclick="ResetGame">إعادة المحاولة</button>
        }
    </div>
</div>

@code {
    private int playerHealth = 100;
    private int enemyHealth = 100;
    private string playerAnimClass = "";
    private string enemyAnimClass = "";
    private string currentCodeTask = "int x = \"5\";"; // مثال بسيط
    private string[] currentOptions = { "int x = 5;", "string x = 5;", "var x = '5';" };
    private int timerValue = 100;
    private bool gameOver = false;

    private void ResetGame()
    {
        playerHealth = 100;
        enemyHealth = 100;
        gameOver = false;
        timerValue = 100;
        StateHasChanged(); // لتحديث الواجهة فوراً
    }

    private async Task CheckAnswer(string answer)
    {
        if (answer == "int x = 5;") // الإجابة الصحيحة
        {
            enemyHealth -= 25;
            playerAnimClass = "attack-anim"; // CSS Animation
            await JS.InvokeVoidAsync("playHitSound");
        }
        else
        {
            playerHealth -= 20;
            enemyAnimClass = "enemy-attack-anim";
        }

        if (enemyHealth <= 0 || playerHealth <= 0) gameOver = true;

        StateHasChanged();
        await Task.Delay(500);
        playerAnimClass = ""; enemyAnimClass = "";
    }
}