        public double Y { get; set; } 
        public double Width { get; set; } 
        public double Height { get; set; } 
        public string ImageUrl { get; set; } = ""; public GameObjectType Type { get; set; } 
        public bool IsAggressive { get; set; } 
        public MoveDirection Direction { get; set; }
        public double Speed { get; set; } 
        public bool IsDestroyed { get; set; } = false;
    }
    public enum MoveDirection { Up, Down }
    public enum GameObjectType { Enemy, Hole , PeacefulCar }
    public class Bullet { public double X { get; set; } public double Y { get; set; } }
    public class Explosion { public double X { get; set; } public double Y { get; set; } public DateTime CreationTime { get; set; } }

