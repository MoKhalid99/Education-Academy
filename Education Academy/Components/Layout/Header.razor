@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inject EducationAcademy.Services.IProgressionService ProgressionService
@inject AuthenticationStateProvider AuthStateProvider

<div class="head_section_container">
    <div class="top_head_section">
        <div class="container_for_notes_title">
            <img class="open_book_pic" src="gp images/Book open.png" />
            <p class="education_academy">Education Academy</p>
        </div>
        <div class="container_for_notes_title">
            <div class="search_div">
                <button class="search_menu">
                    <img src="gp images/search menu.png" alt="" class="search_menu_photo" />
                </button>
                <input id="search" type="text" placeholder="ابحث هنا" class="search_here" />
                <button class="search_menu">
                    <img src="gp images/search lens.png" alt="" class="search_lens" />
                </button>
            </div>
        </div>
    </div>

    <div class="low_head_section">
        @* الرابط الرئيسي متاح للجميع *@
        <NavLink href="/" Match="NavLinkMatch.All">
            <button class="low_section_buttons">
                <p class="low_section_buttons_text">الرئيسية</p>
            </button>
        </NavLink>

        <AuthorizeView>
            <Authorized>
                @* هذه الروابط لا تظهر إلا للمسجلين فقط *@
                <NavLink href="/games">
                    <button class="low_section_buttons">
                        <p class="low_section_buttons_text">الألعاب</p>
                    </button>
                </NavLink>

                <NavLink href="/about">
                    <button class="low_section_buttons">
                        <p class="low_section_buttons_text">عننا</p>
                    </button>
                </NavLink>
                <NavLink href="https://www.facebook.com/csc.o6i">
                    <button class="low_section_buttons">
                        <p class="low_section_buttons_text">تواصل معانا</p>
                    </button>
                </NavLink>
                <NavLink href="/">
                    <button class="low_section_buttons">
                        <p class="low_section_buttons_text">AI اسأل </p>
                    </button>
                </NavLink>
                <NavLink href="/courses">
                    <button class="low_section_buttons">
                        <p class="low_section_buttons_text">كورسات جامعية</p>
                    </button>
                </NavLink>
                <NavLink href="/noop">
                    <button class="low_section_buttons">
                        <p class="low_section_buttons_text">كورسات خارجية</p>
                    </button>
                </NavLink>
            </Authorized>
        </AuthorizeView>

        @* قسم أزرار تسجيل الدخول والخروج *@
        <div class="auth_buttons_container">
            <AuthorizeView>
                <Authorized>
                    @* عرض اسم المستخدم بجواره النجوم *@
                    <div class="user-profile-container">
                        <span class="user_name">@context.User.Identity?.Name</span>
                        
                        <div class="stars-container" title="مستوى الخبرة: @userXP XP">
                            @for (int i = 0; i < 4; i++)
                            {
                                <span class="star @GetStarClass(i)">★</span>
                            }
                        </div>
                    </div>

                    <a href="account/logout" class="low_section_buttons_special2" style="text-decoration: none;">
                        تسجيل خروج
                    </a>
                </Authorized>
                <NotAuthorized>
                    @* يظهر فقط إذا لم يسجل الدخول *@
                    <NavLink href="/register">
                        <button class="low_section_buttons_special">سجل معانا</button>
                    </NavLink>
                    <NavLink href="/login">
                        <button class="low_section_buttons_special2">دخول</button>
                    </NavLink>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </div>
</div>

@code {
    private int userXP = 0;
    // الامتحان بيعطي 30 نقطة
    private int xpPerTest = 30; 

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity is { IsAuthenticated: true })
        {
            var userId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            if (!string.IsNullOrEmpty(userId))
            {
                // جلب نقاط الـ XP للمستخدم من قاعدة البيانات
                userXP = await ProgressionService.GetUserXPAsync(userId);
            }
        }
    }

    private string GetStarClass(int starIndex)
    {
        // حساب عدد الأثلاث بناءً على مقدار النقاط
        int totalThirds = userXP / xpPerTest;
        
        //  (كل نجمة تأخذ 3 أثلاث)
        int thirdsForThisStar = totalThirds - (starIndex * 3);

        if (thirdsForThisStar >= 3) return "full";
        if (thirdsForThisStar == 2) return "two-thirds";
        if (thirdsForThisStar == 1) return "one-third";
        return "empty";
    }
}

<style>
  .head_section_container {
      display: flex;
      flex-direction: column;
      position: sticky;
      top: 0;
      background-color: white;
      z-index: 1000;
      box-shadow: 0 2px 5px rgba(0,0,0,0.1);
  }

  .top_head_section {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 10px 45px;
  }

  .container_for_notes_title {
      display: flex;
      align-items: center;
  }

  .education_academy {
      font-family: 'roboto', sans-serif;
      font-weight: bold;
      font-size: 20px;
      margin-left: 20px;
  }

  .open_book_pic {
      height: 50px;
  }

  .search_div {
      background-color: rgb(212, 212, 212);
      display: flex;
      align-items: center;
      border-radius: 20px;
  }

  .search_here {
      border-radius: 20px;
      height: 35px;
      padding: 0 15px;
      font-size: 16px;
      border: none;
      background-color: lightgray;
  }

  .low_head_section {
      display: flex;
      justify-content: center;
      gap: 20px;
      padding: 15px 0;
      border-top: 1px solid #eee;
  }

  .low_section_buttons {
      border: none;
      background-color: transparent;
      cursor: pointer;
      font-size: 18px;
      font-weight: bold;
      transition: color 0.2s;
  }

  .low_section_buttons:hover { color: orange; }

  .low_section_buttons_special {
      background-color: #4b7983;
      color: white;
      padding: 5px 20px;
      border-radius: 7px;
      border: none;
      cursor: pointer;
  }
  
  .low_section_buttons_special2 {
      background-color: #4b7983;
      color: white;
      padding: 5px 20px;
      border-radius: 7px;
      border: none;
      cursor: pointer;
      margin-right: 10px;
  }

  .auth_buttons_container {
      display: flex;
      align-items: center;
      gap: 15px;
  }

  .user-profile-container {
      display: flex;
      align-items: center;
      gap: 10px;
  }

  .user_name {
      font-size: 16px;
      color: #4b7983;
      font-weight: bold;
      margin: 0;
  }

  /* تنسيقات النجوم */
  .stars-container {
      display: inline-flex;
      direction: ltr; /* لجعل التعبئة من اليسار لليمين  */
      gap: 3px;
  }

  .star {
      position: relative;
      font-size: 22px;
      color: #e0e0e0; /* لون النجمة الفارغة */
      display: inline-block;
  }

  .star::after {
      content: '★';
      position: absolute;
      left: 0;
      top: 0;
      color: #ffb822; /* لون النجمة الممتلئة */
      overflow: hidden;
      width: 0;
      transition: width 0.3s ease;
  }

  .star.one-third::after { width: 33.33%; }
  .star.two-thirds::after { width: 66.66%; }
  .star.full::after { width: 100%; }

</style>