@using Microsoft.AspNetCore.Components.Authorization
@*تم التعديل على بعض النقاط*@
<div class="head_section_container">
    <div class="top_head_section">
        <div class="container_for_notes_title">
            <img class="open_book_pic" src="gp images/Book open.png" />
            <p class="education_academy">Education Academy</p>
        </div>
        <div class="container_for_notes_title">
            <div class="search_div">
                <button class="search_menu">
                    <img src="gp images/search menu.png" alt="" class="search_menu_photo" />
                </button>
                <input id="search" type="text" placeholder="ابحث هنا" class="search_here" />
                <button class="search_menu">
                    <img src="gp images/search lens.png" alt="" class="search_lens" />
                </button>
            </div>
        </div>
    </div>

    <div class="low_head_section">
        @* الرابط الرئيسي متاح للجميع *@
        <NavLink href="/" Match="NavLinkMatch.All">
            <button class="low_section_buttons">
                <p class="low_section_buttons_text">الرئيسية</p>
            </button>
        </NavLink>

        <AuthorizeView>
            <Authorized>
                @* هذه الروابط لا تظهر إلا للمسجلين فقط *@
                <NavLink href="/games">
                    <button class="low_section_buttons">
                        <p class="low_section_buttons_text">الألعاب</p>
                    </button>
                </NavLink>

                <NavLink href="/about">
                    <button class="low_section_buttons">
                        <p class="low_section_buttons_text">عننا</p>
                    </button>
                </NavLink>
                <NavLink href="https://www.facebook.com/csc.o6i">
                    <button class="low_section_buttons">
                        <p class="low_section_buttons_text">تواصل معانا</p>
                    </button>
                </NavLink>
                <NavLink href="/">
                    <button class="low_section_buttons">
                        <p class="low_section_buttons_text">AI اسأل </p>
                    </button>
                </NavLink>
                <NavLink href="/courses">
                    <button class="low_section_buttons">
                        <p class="low_section_buttons_text">كورسات جامعية</p>
                    </button>
                </NavLink>
                <NavLink href="/noop">
                    <button class="low_section_buttons">
                        <p class="low_section_buttons_text">كورسات خارجية</p>
                    </button>
                </NavLink>
            </Authorized>
        </AuthorizeView>

        @* قسم أزرار تسجيل الدخول والخروج *@
        <div class="auth_buttons_container">
            <AuthorizeView>
                <Authorized>
                    @* يظهر عند تسجيل الدخول *@
                    <span class="user_name">مرحباً، @context.User.Identity?.Name</span>
                    <form action="Account/Logout" method="post" style="display:inline">
                        <AntiforgeryToken />
                    </form>
                </Authorized>
                <NotAuthorized>
                    @* يظهر فقط إذا لم يسجل الدخول *@
                    <NavLink href="/register">
                        <button class="low_section_buttons_special">سجل معانا</button>
                    </NavLink>
                    <NavLink href="/login">
                        <button class="low_section_buttons_special2">دخول</button>
                    </NavLink>
                </NotAuthorized>
            </AuthorizeView>
            <AuthorizeView>
                <Authorized>
                    @* نستخدم <a> بدلاً من <NavLink> هنا لأننا نحتاج لعمل Refresh كامل للمتصفح لمسح حالة التسجيل *@
                    <a href="account/logout" class="low_section_buttons_special2" style="text-decoration: none;">
                        تسجيل خروج
                    </a>
                </Authorized>
               </AuthorizeView>
        </div>
    </div>
</div>

 <style>
  .head_section_container {
  display: flex;
  flex-direction: column;
  position: sticky;
  top: 0;
  background-color: white;
  z-index: 1000;
  box-shadow: 0 2px 5px rgba(0,0,0,0.1);
}

.top_head_section {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10px 45px;
}

.container_for_notes_title {
  display: flex;
  align-items: center;
}

.education_academy {
  font-family: 'roboto', sans-serif;
  font-weight: bold;
  font-size: 20px;
  margin-left: 20px;
}

.open_book_pic {
  height: 50px;
}

.search_div {
  background-color: rgb(212, 212, 212);
  display: flex;
  align-items: center;
  border-radius: 20px;
}

.search_here {
  border-radius: 20px;
  height: 35px;
  padding: 0 15px;
  font-size: 16px;
  border: none;
  background-color: lightgray;
}

.low_head_section {
  display: flex;
  justify-content: center;
  gap: 20px;
  padding: 15px 0;
  border-top: 1px solid #eee;
}

.low_section_buttons {
  border: none;
  background-color: transparent;
  cursor: pointer;
  font-size: 18px;
  font-weight: bold;
  transition: color 0.2s;
}

.low_section_buttons:hover { color: orange; }

.low_section_buttons_special {
  background-color: #4b7983;
  color: white;
  padding: 5px 20px;
  border-radius: 7px;
  border: none;
  cursor: pointer;
}

.user_name {
        font-size: 14px;
        color: #4b7983;
        font-weight: bold;
  }

</style>