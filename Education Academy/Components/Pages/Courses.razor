@page "/courses"
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthStateProvider
@inject HttpClient Http
@inject EducationAcademy.Services.IProgressionService ProgressionService
<div class="courses_div">كورسات</div>
<div class="courses_container">

    <div class="courses_lines">
        @for (int i = 0; i <= 2; i++)
        {
            var levelId = i;
            var isLocked = IsLevelLocked(levelId);

            <div class="anchor_container @(isLocked ? "level-locked" : "")">
                <a class="courses_buttons_anchor" href="@(isLocked ? null : $"/level-details/{levelId}")">
                    <button class="courses_buttons" disabled="@isLocked">

                        @if (isLocked)
                        {
                            <div class="lock-overlay">🔒</div>
                        }

                        <img src="gp images/level@(levelId).png" alt="" class="courses_icons" />
                        <p class="courses_titles">LEVEL @levelId</p>
                    </button>
                </a>
            </div>
        }
    </div>

    <div class="courses_lines">
        @for (int i = 3; i <= 4; i++)
        {
            var levelId = i;
            var isLocked = IsLevelLocked(levelId);

            <div class="anchor_container @(isLocked ? "level-locked" : "")">
                <a class="courses_buttons_anchor" href="@(isLocked ? null : $"/level-details/{levelId}")">
                    <button class="courses_buttons" disabled="@isLocked">

                        @if (isLocked)
                        {
                            <div class="lock-overlay">🔒</div>
                        }

                        <img src="gp images/level@(levelId).png" alt="" class="courses_icons" />
                        <p class="courses_titles">LEVEL @levelId</p>
                    </button>
                </a>
            </div>
        }

        <div class="anchor_container">
            <a class="courses_buttons_anchor" href="/games">
                <button class="courses_buttons">
                    <img src="gp images/gamepad logo.png" alt="" class="courses_icons" />
                    <p class="courses_titles">GAMES</p>
                </button>
            </a>
        </div>
    </div>

</div>
<style>
    .courses_div {
        text-align: right;
        padding: 40px 10%;
        font-size: 35px;
        font-weight: bold;
    }

    .courses_container {
        display: flex;
        flex-direction: column;
        gap: 50px;
        padding: 0 10% 100px 10%;
    }

    .courses_lines {
        display: flex;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 20px;
    }

    .courses_buttons {
        background: white;
        border: 1px solid #ddd;
        border-radius: 20px;
        overflow: hidden;
        transition: transform 0.3s;
        box-shadow: 0 4px 8px rgba(0,0,0,0.1);
    }

        .courses_buttons:hover {
            transform: translateY(-10px) scale(1.05);
        }

    .courses_icons {
        width: 280px;
        height: 180px;
        object-fit: cover;
    }

    .courses_titles {
        font-size: 24px;
        font-weight: bold;
        padding: 15px 0;
        margin: 0;
        border-top: 1px solid #eee;

        level-locked {
            opacity: 0.6;
            cursor: not-allowed;
        }

        .lock-overlay {
            position: absolute;
            top: 10px;
            right: 10px;
            font-size: 24px;
            z-index: 10;
        }

        .courses_buttons:disabled {
            pointer-events: none;
        }
    }
</style>
@code{
    private int userXP = 0;
    private int maxLevel = 1;
    private bool isAdmin = false;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity != null && user.Identity.IsAuthenticated)
        {
            isAdmin = user.IsInRole("Admin");
            var userId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

            if (!string.IsNullOrEmpty(userId))
            {
                // جلب البيانات مباشرة من الخدمة وليس من رابط API
                userXP = await ProgressionService.GetUserXPAsync(userId);

                // جلب أقصى مستوى وصل إليه المستخدم (تحتاج لإضافة دالة في الخدمة أو جلب المستخدم كاملاً)
                // لنفترض أننا سنعتمد على الـ XP لفتح الأقفال حالياً
            }
        }
    }

    private bool IsLevelLocked(int levelId)
    {
        if (isAdmin) return false;
        if (levelId <= 0) return false;

        // منطق فتح الأقفال بناءً على الـ XP (تأكد أن القيم متوافقة مع AcademyDbContext)
        if (levelId == 1 && userXP >= 100) return false;
        if (levelId == 2 && userXP >= 200) return false;
        if (levelId == 3 && userXP >= 200) return false;
        if (levelId == 4 && userXP >= 300) return false;

        return true;
    }
}