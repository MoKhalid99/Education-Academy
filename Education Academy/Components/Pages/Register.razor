@page "/register"
@using Education_Academy.Components.Layout
@using EducationAcademy.Models
@using Microsoft.AspNetCore.Identity
@layout EmptyLayout
@inject UserManager<ApplicationUser> UserManager
@inject SignInManager<ApplicationUser> SignInManager
@inject NavigationManager NavigationManager
@*بص يا معلم ضبطت الشكل الاستايل بيبدأ من75*@
<PageTitle>إنشاء حساب - Education Academy</PageTitle>

<div class="auth-wrapper">
    <div class="auth-card">
        <h2 class="auth-title">إنشاء حساب جديد</h2>

<Component1 />
        <form action="account/register" method="post">
            <AntiforgeryToken />
            @*الاسم*@
            <div class="form-group">
                <input name="fullName" type="text" class="form-input" placeholder="الاسم الكامل" required />
            </div>
            @*الايميل*@
            <div class="form-group">
                <input name="email" type="email" class="form-input" placeholder="الايميل" required />
            </div>

            <div class="form-group">
                @* التحقق من رقم الهاتف المصري عبر Regex في المتصفح *@
                <input name="phone" type="tel" class="form-input" placeholder="رقم الهاتف (01x...)"
                       pattern="^(010|011|012|015)[0-9]{8}$" title="يرجى إدخال رقم هاتف مصري صحيح" required />
            </div>
            @*باسورد*@
            <div class="form-group">
                <input name="password" type="password" class="form-input" placeholder="كلمة المرور" required />
            </div>

            <button type="submit" class="btn-primary">تسجيل</button>
        </form>

        <div class="login-redirect">
            لديك حساب بالفعل؟ <a href="/login" class="redirect-link">سجل دخولك</a>
        </div>
    </div>
</div>
@code {
    private RegisterModel registerModel = new();
    private string? errorMessage;
    //بيانات التي تم إدخالها في الفورم
    private async Task HandleRegister()
    {
        var user = new ApplicationUser
        {
            UserName = registerModel.Email,
            Email = registerModel.Email,
            FullName = registerModel.FullName,
            PhoneNumber = registerModel.Phone,
            //لاي طالب حديث      
            XP = 0,
            CurrentLevel = 1
        };

        var result = await UserManager.CreateAsync(user, registerModel.Password);

        if (result.Succeeded)
        {
            await SignInManager.SignInAsync(user, isPersistent: true);
            NavigationManager.NavigateTo("/");
        }
        else
        {
            errorMessage = string.Join(", ", result.Errors.Select(e => e.Description));
        }
    }
}
<style>
    /* Layout */
    .auth-wrapper {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 60vh;
        padding: 2rem 1rem;
        direction: rtl;
    }

    /* Card */
    .auth-card {
        width: 100%;
        max-width: 360px;
        background: linear-gradient(160deg, #6ba3a8 0%, #4a7c80 40%, #2e5f63 100%);
        border-radius: 18px;
        padding: 2.5rem 2rem 2rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.85rem;
        box-shadow: 0 8px 32px rgba(46, 95, 99, 0.35);
    }

    /* Title */
    .auth-title {
        color: #fff;
        font-size: 1.25rem;
        font-weight: 700;
        margin: 0 0 0.5rem;
        text-align: center;
        letter-spacing: 0.12em;
        text-transform: uppercase;
    }

    /* Form */
    .form-group {
        width: 100%;
    }

    .form-input {
        width: 100%;
        padding: 0.6rem 1rem;
        border: none;
        border-radius: 8px;
        background: rgba(255,255,255,0.82);
        color: #333;
        font-size: 0.95rem;
        text-align: right;
        outline: none;
        transition: background 0.2s;
        box-sizing: border-box;
    }

        .form-input:focus {
            background: rgba(255,255,255,0.95);
        }

        .form-input::placeholder {
            color: #888;
            text-align: right;
        }

    /* Submit Button */
    .btn-primary {
        width: 120px;
        padding: 0.5rem 0;
        border: none;
        border-radius: 8px;
        background: rgba(255,255,255,0.9);
        color: #2e5f63;
        font-size: 0.95rem;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.2s, transform 0.1s;
        margin-top: 0.25rem;
    }

        .btn-primary:hover {
            background: #fff;
            transform: translateY(-1px);
        }

    /* Redirect link */
    .login-redirect {
        color: rgba(255,255,255,0.8);
        font-size: 0.82rem;
        margin: 0;
        text-align: center;
    }

    .redirect-link {
        color: #fff;
        font-weight: 600;
        text-decoration: underline;
        transition: opacity 0.2s;
    }

        .redirect-link:hover {
            opacity: 0.8;
        }

    /* Divider */
    .divider-text {
        color: rgba(255,255,255,0.75);
        font-size: 0.85rem;
        margin: 0;
    }

    /* Social Icons */
    .social-icons {
        display: flex;
        gap: 0.75rem;
        align-items: center;
    }

    .social-icon {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: rgba(255,255,255,0.15);
        transition: background 0.2s, transform 0.15s;
        text-decoration: none;
    }

        .social-icon:hover {
            background: rgba(255,255,255,0.3);
            transform: translateY(-2px);
        }

    /* Validation messages */
    .validation-message {
        color: #ffe08a;
        font-size: 0.78rem;
        margin-top: 3px;
        text-align: right;
    }
</style>
