@page "/register"
@using Education_Academy.Components.Layout
@layout EmptyLayout

<PageTitle>تسجيل - Education Academy</PageTitle>

<div class="auth-wrapper">
    <div class="auth-card">
        <h2 class="auth-title">LOG IN</h2>

        <EditForm Model="registerModel" OnValidSubmit="HandleRegister" FormName="RegisterForm">
            <DataAnnotationsValidator />

            <div class="form-group">
                <InputText @bind-Value="registerModel.FullName"
                           class="form-input"
                           placeholder="الاسم" />
                <ValidationMessage For="() => registerModel.FullName" />
            </div>

            <div class="form-group">
                <InputText @bind-Value="registerModel.Email"
                           class="form-input"
                           placeholder="الايميل" />
                <ValidationMessage For="() => registerModel.Email" />
            </div>

            <div class="form-group">
                <InputText @bind-Value="registerModel.Phone"
                           class="form-input"
                           placeholder="رقم الهاتف" />
                <ValidationMessage For="() => registerModel.Phone" />
            </div>

            <div class="form-group">
                <InputText @bind-Value="registerModel.Password"
                           type="password"
                           class="form-input"
                           placeholder="الباسورد" />
                <ValidationMessage For="() => registerModel.Password" />
            </div>

            <button type="submit" class="btn-primary">تسجيل</button>
        </EditForm>

        <p class="login-redirect">
            ليس لديك حساب؟
            <a href="/login" class="redirect-link">سجل الان</a>
        </p>

        <p class="divider-text">او</p>

        <div class="social-icons">
            <a href="#" class="social-icon google" title="Google">
                <svg viewBox="0 0 24 24" width="22" height="22">
                    <path fill="#EA4335" d="M5.26620003,9.76452941 C6.19878754,6.93863203 8.85444915,4.90909091 12,4.90909091 C13.6085365,4.90909091 15.0693182,5.44772727 16.2436909,6.34113636 L19.4231818,3.16161616 C17.4330727,1.20670455 14.8512727,0 12,0 C7.27575182,0 3.19860227,2.81070455 1.24004773,6.86363636 L5.26620003,9.76452941 Z" />
                    <path fill="#34A853" d="M16.0407269,18.0125889 C14.9509167,18.7163016 13.5660892,19.0909091 12,19.0909091 C8.86648613,19.0909091 6.21911939,17.076871 5.27698177,14.2678769 L1.23746264,17.1677788 C3.19279051,21.2237096 7.26500293,24 12,24 C14.7347449,24 17.2851555,23.0770994 19.2412051,21.5329965 L16.0407269,18.0125889 Z" />
                    <path fill="#4A90D9" d="M19.2412051,21.5329965 C21.2980725,19.8855573 22.7420453,17.4196052 23.3836021,14.4862091 L23.3836021,12.1818182 L12,12.1818182 L12,15.8181818 L19.8622003,15.8181818 C19.5411268,17.2297727 18.7598654,18.4393898 17.6854973,19.2678769 L19.2412051,21.5329965 Z" />
                    <path fill="#FBBC05" d="M5.27698177,14.2678769 C5.03832634,13.556323 4.90909091,12.7937589 4.90909091,12 C4.90909091,11.2182781 5.03443647,10.4668121 5.26620003,9.76452941 L1.24004773,6.86363636 C0.447688254,8.43649071 0,10.1644052 0,12 C0,13.8405927 0.448442437,15.5753764 1.23746264,17.1677788 L5.27698177,14.2678769 Z" />
                </svg>
            </a>
            <a href="#" class="social-icon facebook" title="Facebook">
                <svg viewBox="0 0 24 24" width="22" height="22" fill="#1877F2">
                    <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
                </svg>
            </a>
            <a href="#" class="social-icon twitter" title="Twitter">
                <svg viewBox="0 0 24 24" width="22" height="22" fill="#1DA1F2">
                    <path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z" />
                </svg>
            </a>
            <a href="#" class="social-icon linkedin" title="LinkedIn">
                <svg viewBox="0 0 24 24" width="22" height="22" fill="#0A66C2">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
                </svg>
            </a>
        </div>
    </div>
</div>

@code {
    private RegisterModel registerModel = new();

    private async Task HandleRegister()
    {
        // TODO: implement registration logic
        await Task.CompletedTask;
    }

    public class RegisterModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "الاسم مطلوب")]
        public string FullName { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "الايميل مطلوب")]
        [System.ComponentModel.DataAnnotations.EmailAddress(ErrorMessage = "صيغة الايميل غير صحيحة")]
        public string Email { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "رقم الهاتف مطلوب")]
        public string Phone { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "الباسورد مطلوب")]
        [System.ComponentModel.DataAnnotations.MinLength(6, ErrorMessage = "الباسورد يجب أن يكون 6 أحرف على الأقل")]
        public string Password { get; set; } = string.Empty;
    }
}

<style>
    /* ── Layout ── */
    .auth-wrapper {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 60vh;
        padding: 2rem 1rem;
        direction: rtl;
    }

    /* ── Card ── */
    .auth-card {
        width: 100%;
        max-width: 360px;
        background: linear-gradient(160deg, #6ba3a8 0%, #4a7c80 40%, #2e5f63 100%);
        border-radius: 18px;
        padding: 2.5rem 2rem 2rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.85rem;
        box-shadow: 0 8px 32px rgba(46, 95, 99, 0.35);
    }

    /* ── Title ── */
    .auth-title {
        color: #fff;
        font-size: 1.25rem;
        font-weight: 700;
        margin: 0 0 0.5rem;
        text-align: center;
        letter-spacing: 0.12em;
        text-transform: uppercase;
    }

    /* ── Form ── */
    .form-group {
        width: 100%;
    }

    .form-input {
        width: 100%;
        padding: 0.6rem 1rem;
        border: none;
        border-radius: 8px;
        background: rgba(255,255,255,0.82);
        color: #333;
        font-size: 0.95rem;
        text-align: right;
        outline: none;
        transition: background 0.2s;
        box-sizing: border-box;
    }

        .form-input:focus {
            background: rgba(255,255,255,0.95);
        }

        .form-input::placeholder {
            color: #888;
            text-align: right;
        }

    /* ── Submit Button ── */
    .btn-primary {
        width: 120px;
        padding: 0.5rem 0;
        border: none;
        border-radius: 8px;
        background: rgba(255,255,255,0.9);
        color: #2e5f63;
        font-size: 0.95rem;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.2s, transform 0.1s;
        margin-top: 0.25rem;
    }

        .btn-primary:hover {
            background: #fff;
            transform: translateY(-1px);
        }

    /* ── Redirect link ── */
    .login-redirect {
        color: rgba(255,255,255,0.8);
        font-size: 0.82rem;
        margin: 0;
        text-align: center;
    }

    .redirect-link {
        color: #fff;
        font-weight: 600;
        text-decoration: underline;
        transition: opacity 0.2s;
    }

        .redirect-link:hover {
            opacity: 0.8;
        }

    /* ── Divider ── */
    .divider-text {
        color: rgba(255,255,255,0.75);
        font-size: 0.85rem;
        margin: 0;
    }

    /* ── Social Icons ── */
    .social-icons {
        display: flex;
        gap: 0.75rem;
        align-items: center;
    }

    .social-icon {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: rgba(255,255,255,0.15);
        transition: background 0.2s, transform 0.15s;
        text-decoration: none;
    }

        .social-icon:hover {
            background: rgba(255,255,255,0.3);
            transform: translateY(-2px);
        }

    /* ── Validation messages ── */
    .validation-message {
        color: #ffe08a;
        font-size: 0.78rem;
        margin-top: 3px;
        text-align: right;
    }
</style>
