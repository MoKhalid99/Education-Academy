@page "/roadmap"
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthProvider

<div class="staircase-container">
    <h2 class="text-center mb-5">رحلتك البرمجية</h2>

    @for (int i = 0; i < 4; i++) // الأربعة ليفلات
    {
        var levelIndex = i;
        bool isLocked = currentUserLevel < levelIndex;

        <div class="stair-step @(isLocked ? "locked" : "unlocked")"
             style="margin-right: @(levelIndex * 80)px">

            <div class="step-card shadow-lg @(levelIndex == currentUserLevel ? "active-glow" : "")"
                 @onclick="() => OpenLevel(levelIndex)">

                <div class="level-icon">
                    @if (isLocked)
                    {
                        <i class="fas fa-lock"></i>
                    }
                    else
                    {

                        <span class="level-number">@levelIndex</span>
                    }
                </div>

                <div class="step-info">
                    <h4>المستوى @levelIndex</h4>
                    <p>@(GetLevelName(levelIndex))</p>
                </div>

                @if (!isLocked)
                {
                    <div class="xp-bar">
                        <div class="xp-progress" style="width: @(userXP)%"></div>
                    </div>
                }
            </div>

            @if (levelIndex < 3) // رسم السهم الواصل للدرجة التالية
            {
                <div class="connector-line"></div>
            }
        </div>
    }
</div>

<style>
    .staircase-container { padding: 50px; background: #f0f4f8; min-height: 100vh; }
    .stair-step { position: relative; display: flex; align-items: center; margin-bottom: 60px; transition: 0.5s; }
    .step-card {
        width: 280px; padding: 20px; border-radius: 25px; background: white;
        cursor: pointer; border: 3px solid transparent; transition: 0.3s;
    }
    .locked { opacity: 0.6; filter: grayscale(1); cursor: not-allowed; }
    .unlocked .step-card:hover { transform: scale(1.05); border-color: #4db6ac; }
    .active-glow { box-shadow: 0 0 20px rgba(77, 182, 172, 0.5); border-color: #4db6ac; }
    .connector-line {
        position: absolute; bottom: -50px; left: 50px;
        width: 4px; height: 50px; background: #b0bec5;
    }
    .xp-bar { height: 8px; background: #eee; border-radius: 4px; margin-top: 10px; overflow: hidden; }
    .xp-progress { height: 100%; background: #4db6ac; transition: 1s; }
</style>

@code {
    private int currentUserLevel = 0; // سيجلب من قاعدة البيانات
    private int userXP = 45; // سيجلب من قاعدة البيانات

    private void OpenLevel(int level)
    {
        if (level <= currentUserLevel) Nav.NavigateTo($"/level/{level}");
    }

    private string GetLevelName(int lv) => lv switch
    {
        0 => "أساسيات المنطق",
        1 => "هياكل البيانات",
        2 => "البرمجة الكائنية",
        3 => "بناء المشاريع",
        _ => ""
    };
}