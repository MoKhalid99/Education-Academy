@page "/roadmap"
@using EducationAcademy.Models
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@inject NavigationManager Nav  
@inject AuthenticationStateProvider AuthProvider
@inject UserManager<ApplicationUser> UserManager
@*لوجيك لا يجب العبث به*@
<div class="staircase-container">
    <h2 class="text-center mb-5">رحلتك البرمجية</h2>

    @for (int i = 1; i <= 4; i++)
    {
        var levelIndex = i;
        bool isLocked = currentUserLevel < levelIndex && !isAdmin;

        <div class="stair-step @(isLocked ? "locked" : "unlocked")"
             style="margin-right: @((levelIndex - 1) * 80)px">

            <div class="step-card shadow-lg @(levelIndex == currentUserLevel ? "active-glow" : "")"
                 @onclick="() => OpenLevel(levelIndex)">

                <div class="level-icon">
                    @if (isLocked)
                    {
                        <i class="fas fa-lock"></i>
                    }
                    else
                    {
                        <span class="level-number">@levelIndex</span>
                    }
                </div>

                <div class="step-info">
                    <h4>المستوى @levelIndex</h4>
                    <p>@GetLevelName(levelIndex)</p>
                </div>

                @if (!isLocked)
                {
                    <div class="xp-bar">
                        <div class="xp-progress" style="width: @(CalculateProgress(levelIndex))%"></div>
                    </div>
                }
            </div>
            @if (levelIndex < 4)
            {
                <div class="connector-line"></div>
            }
        </div>
    }
</div>
<style>
    .staircase-container { padding: 50px; background: #f0f4f8; min-height: 100vh; }
    .stair-step { position: relative; display: flex; align-items: center; margin-bottom: 60px; transition: 0.5s; }
    .step-card {
        width: 280px; padding: 20px; border-radius: 25px; background: white;
        cursor: pointer; border: 3px solid transparent; transition: 0.3s;
    }
    .locked { opacity: 0.6; filter: grayscale(1); cursor: not-allowed; }
    .unlocked .step-card:hover { transform: scale(1.05); border-color: #4db6ac; }
    .active-glow { box-shadow: 0 0 20px rgba(77, 182, 172, 0.5); border-color: #4db6ac; }
    .connector-line {
        position: absolute; bottom: -50px; left: 50px;
        width: 4px; height: 50px; background: #b0bec5;
    }
    .xp-bar { height: 8px; background: #eee; border-radius: 4px; margin-top: 10px; overflow: hidden; }
    .xp-progress { height: 100%; background: #4db6ac; transition: 1s; }
</style>

@code {
    private int currentUserLevel = 1;
    private int userXP = 0;
    private bool isAdmin = false; // تعريف المتغير المفقود

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthProvider.GetAuthenticationStateAsync();
        var user = await UserManager.GetUserAsync(authState.User);

        if (user != null)
        {
            currentUserLevel = user.CurrentLevel;
            userXP = user.XP;
            isAdmin = user.IsAdmin; // تحديث القيمة
        }
    }

    // تعريف الدالة المفقودة CalculateProgress
    private int CalculateProgress(int level)
    {
        if (level < currentUserLevel) return 100;
        if (level > currentUserLevel) return 0;
        return userXP % 100;
    }

    // تعريف الدالة المفقودة GetLevelName
    private string GetLevelName(int i) => i switch
    {
        1 => "أساسيات البرمجة",
        2 => "هياكل البيانات",
        3 => "خوارزميات متقدمة",
        4 => "مشروع التخرج",
        _ => ""
    };

    private void OpenLevel(int level)
    {
        if (currentUserLevel >= level || isAdmin)
        {
            Nav.NavigateTo($"/level-content/{level}");
        }
    }
}