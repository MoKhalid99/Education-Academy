@page "/login"
@using Education_Academy.Components.Layout
@using EducationAcademy.Models
@using Microsoft.AspNetCore.Identity
@layout EmptyLayout
@inject SignInManager<ApplicationUser> SignInManager
@inject NavigationManager NavigationManager

<PageTitle>تسجيل الدخول - Education Academy</PageTitle>

<div class="big_container">
    <div class="container">
        <div>
            <form action="account/login" method="post" class="form_container">
                <AntiforgeryToken />

                <input name="email" type="email" placeholder="الايميل" required />
                <input name="password" type="password" placeholder="كلمة السر" required />

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div style="color: red; font-size: 14px; text-align: center; margin-top: -10px;">@errorMessage</div>
                }

                <button type="submit" class="register_button">سجل الدخول</button>

                <div class="login-redirect">
                    ليس لديك حساب؟
                    <a href="/register" class="redirect-link">أنشئ حساباً الآن</a>
                </div>
            </form>
        </div>
    </div>
</div>

@code {
    private LoginViewModel loginModel = new();
    private string? errorMessage;

    private async Task HandleLogin()
    {
        var result = await SignInManager.PasswordSignInAsync(loginModel.Email, loginModel.Password, isPersistent: true, lockoutOnFailure: false);
        if (result.Succeeded)
        {
            NavigationManager.NavigateTo("/");
        }
        else
        {
            errorMessage = "خطأ في البريد الإلكتروني أو كلمة المرور.";
        }
    }
}

<style>
    /* Layout & Container */
    .big_container {
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        height: 100vh;
        direction: rtl;
    }

    .container {
        display: flex;
        background-image: url("gp images/Frame 2377011.png"); 
        background-repeat: no-repeat;
        background-size: cover;
        background-position-y: bottom;
        border-top-left-radius: 60px;
        height: 627px;
        width: 781px;
        position: relative;
    }

    /* Form */
    .form_container {
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        row-gap: 35px;
        height: 100%;
        position: absolute;
        left: 50%;
        bottom: 30px;
        transform: translateX(-50%);
    }

    /* Inputs */
    input {
        width: 400px;
        height: 50px;
        border-radius: 30px;
        border: none;
        background-color: #F5F5F5;
        font-size: 16px;
        box-shadow: 0px 2px 5px rgba(0, 0, 0, 0.2);
        text-align: center;
        outline: none;
        font-family: inherit;
    }

    ::placeholder {
        text-align: center;
        color: #888;
    }

    /* Button */
    .register_button {
        width: 200px;
        height: 50px;
        border-radius: 30px;
        border: none;
        background-color: white;
        color: #009999;
        font-size: 16px;
        font-weight: bold;
        cursor: pointer;
        transition: 0.25s ease-in-out;
    }

        .register_button:hover {
            background-color: #009999;
            color: white;
            border: 1px solid white;
            transform: scale(1.1);
        }

    /* Links & Redirect */
    .login-redirect {
        color: #333;
        font-size: 15px;
        margin-top: -15px;
        text-align: center;
    }

    .redirect-link {
        color: #009999;
        text-decoration: none;
        font-weight: bold;
        transition: color 0.2s;
    }

        .redirect-link:hover {
            color: #007777;
        }
</style>