@page "/login"
@using Education_Academy.Components.Layout
@using EducationAcademy.Models
@using Microsoft.AspNetCore.Identity
@layout EmptyLayout
@inject SignInManager<ApplicationUser> SignInManager
@inject NavigationManager NavigationManager
@*بص يا معلم عايزك تعد الستايل من اول سطر 56*@
@*و وازن مبين html , css و الباك هنا من38 ل55*@
<PageTitle>تسجيل الدخول - Education Academy</PageTitle>

<div class="auth-wrapper">
    <div class="auth-card">
        <h2 class="auth-title">سجل دخولك</h2>

<Component />
        <form action="account/login" method="post">
            <AntiforgeryToken />

            <div class="form-group">
                <input name="email" type="email" class="form-input" placeholder="الايميل" required />
            </div>

            <div class="form-group">
                <input name="password" type="password" class="form-input" placeholder="الباسورد" required />
            </div>

            <button type="submit" class="btn-primary">دخول</button>
        </form>

        <p class="divider-text">أو</p>
        <div class="login-redirect">
            ليس لديك حساب؟ <a href="/register" class="redirect-link">أنشئ حساباً الآن</a>
        </div>
    </div>
</div>

@code {
    private LoginViewModel loginModel = new();
    private string? errorMessage;

    private async Task HandleLogin()
    {
        var result = await SignInManager.PasswordSignInAsync(loginModel.Email, loginModel.Password, isPersistent: true, lockoutOnFailure: false);

        if (result.Succeeded)
        {
            NavigationManager.NavigateTo("/");
        }
        else
        {
            errorMessage = "خطأ في البريد الإلكتروني أو كلمة المرور.";
        }
    }
}

<style>
    /* Layout */
    .auth-wrapper {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 60vh;
        padding: 2rem 1rem;
        direction: rtl;
    }

    /* Card */
    .auth-card {
        width: 100%;
        max-width: 360px;
        background: linear-gradient(160deg, #6ba3a8 0%, #4a7c80 40%, #2e5f63 100%);
        border-radius: 18px;
        padding: 2.5rem 2rem 2rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.85rem;
        box-shadow: 0 8px 32px rgba(46, 95, 99, 0.35);
    }

    /* Title */
    .auth-title {
        color: #fff;
        font-size: 1.35rem;
        font-weight: 600;
        margin: 0 0 0.5rem;
        text-align: center;
        letter-spacing: 0.03em;
    }

    /* Form */
    .form-group {
        width: 100%;
    }

    .form-input {
        width: 100%;
        padding: 0.6rem 1rem;
        border: none;
        border-radius: 8px;
        background: rgba(255,255,255,0.82);
        color: #333;
        font-size: 0.95rem;
        text-align: right;
        outline: none;
        transition: background 0.2s;
        box-sizing: border-box;
    }

        .form-input:focus {
            background: rgba(255,255,255,0.95);
        }

        .form-input::placeholder {
            color: #888;
            text-align: right;
        }

    /* Submit Button */
    .btn-primary {
        width: 120px;
        padding: 0.5rem 0;
        border: none;
        border-radius: 8px;
        background: rgba(255,255,255,0.9);
        color: #2e5f63;
        font-size: 0.95rem;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.2s, transform 0.1s;
        margin-top: 0.25rem;
    }

        .btn-primary:hover {
            background: #fff;
            transform: translateY(-1px);
        }

    /* Divider */
    .divider-text {
        color: rgba(255,255,255,0.75);
        font-size: 0.85rem;
        margin: 0;
    }

    /* Social Icons */
    .social-icons {
        display: flex;
        gap: 0.75rem;
        align-items: center;
    }

    .social-icon {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: rgba(255,255,255,0.15);
        transition: background 0.2s, transform 0.15s;
        text-decoration: none;
    }

        .social-icon:hover {
            background: rgba(255,255,255,0.3);
            transform: translateY(-2px);
        }

    /* Forgot Link */
    .forgot-link {
        color: rgba(255,255,255,0.85);
        font-size: 0.85rem;
        text-decoration: underline;
        cursor: pointer;
        margin-top: 0.25rem;
        transition: color 0.2s;
    }

        .forgot-link:hover {
            color: #fff;
        }

    /* Validation messages */
    .validation-message {
        color: #ffe08a;
        font-size: 0.78rem;
        margin-top: 3px;
        text-align: right;
    }
</style>
