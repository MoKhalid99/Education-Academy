@page "/forgot-password"
@using Education_Academy.Components.Layout
@using EducationAcademy.Models
@using Microsoft.AspNetCore.Identity
@layout EmptyLayout
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager NavigationManager

<PageTitle>استعادة كلمة المرور - Education Academy</PageTitle>

<div class="big_container">
    <div class="container">
        <div>
            @if (!isEmailSent)
            {
                <form @onsubmit="HandleForgotPassword" class="form_container">
                    <h2 class="form-title">استعادة الحساب</h2>
                    <p class="form-subtitle">أدخل بريدك الإلكتروني لإرسال رابط تعيين كلمة المرور</p>

                    <input type="email" @bind="email" placeholder="الايميل المرتبط بالحساب" required />

                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="error-msg">@errorMessage</div>
                    }

                    <button type="submit" class="register_button" disabled="@isLoading">
                        @(isLoading ? "جاري الإرسال..." : "إرسال الرابط")
                    </button>

                    <div class="links-wrapper">
                        <div class="white-box">
                            <span>تذكرت كلمة السر؟</span>
                            <a href="/login" class="redirect-link">سجل دخولك</a>
                        </div>
                    </div>
                </form>
            }
            else
            {
                <div class="form_container">
                    <div class="success-box">
                        <i class="fas fa-check-circle success-icon"></i>
                        <h3>تم إرسال الرابط!</h3>
                        <p>يرجى مراجعة بريدك الإلكتروني (Inbox/Spam) لإكمال عملية الاستعادة.</p>
                        <a href="/login" class="register_button" style="text-decoration:none; display:flex; align-items:center; justify-content:center;">العودة للدخول</a>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private string email = "";
    private string? errorMessage;
    private bool isLoading = false;
    private bool isEmailSent = false;

    private async Task HandleForgotPassword()
    {
        isLoading = true;
        errorMessage = null;

        var user = await UserManager.FindByEmailAsync(email);
        if (user == null)
        {
            errorMessage = "هذا البريد غير مسجل لدينا.";
            isLoading = false;
            return;
        }

        // هنا يتم إنشاء التوكن (Token) الخاص بالاستعادة
        var token = await UserManager.GeneratePasswordResetTokenAsync(user);

        // ملاحظة: هنا يجب أن يكون لديك خدمة إرسال إيميلات (EmailSender)
        // ليس لدينا لذا سيتم محاكاة النجاح حالياً
        isEmailSent = true;
        isLoading = false;
    }
}

