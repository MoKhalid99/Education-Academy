@page "/feedback"
@using System.Net
@using System.Net.Mail
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components.Authorization

<div class="feedback-wrapper" dir="rtl">

    <div class="feedback-top">

        <div class="feedback-form-side">
            <AuthorizeView Context="authContext">
                <Authorized>
                    @* يظهر للمستخدمين المسجلين فقط *@
                    <EditForm Model="@formModel" OnValidSubmit="HandleSubmit">
                        <DataAnnotationsValidator />

                        <div class="form-group">
                            <label>الاسم</label>
                            <InputText @bind-Value="formModel.Name" class="form-input" />
                            <ValidationMessage For="@(() => formModel.Name)" class="text-danger" />
                        </div>

                        <div class="form-group">
                            <label>رقم الهاتف</label>
                            <InputText @bind-Value="formModel.Phone" class="form-input" type="tel" />
                            <ValidationMessage For="@(() => formModel.Phone)" class="text-danger" />
                        </div>

                        <div class="form-group">
                            <label>البريد الالكتروني</label>
                            <InputText @bind-Value="formModel.Email" class="form-input" type="email" />
                            <ValidationMessage For="@(() => formModel.Email)" class="text-danger" />
                        </div>

                        <div class="form-group">
                            <label>الرسالة</label>
                            <InputTextArea @bind-Value="formModel.Message" class="form-input form-textarea" rows="5" />
                            <ValidationMessage For="@(() => formModel.Message)" class="text-danger" />
                        </div>

                        <button type="submit" class="btn-submit">إرسال</button>

                        @if (!string.IsNullOrEmpty(successMessage))
                        {
                            <div class="alert-success">@successMessage</div>
                        }
                        @if (!string.IsNullOrEmpty(errorMessage))
                        {
                            <div class="alert-error">@errorMessage</div>
                        }
                    </EditForm>
                </Authorized>

                <NotAuthorized>
                    @* يظهر للزوار غير المسجلين *@
                    <div class="auth-warning-box">
                        <svg width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="#1e3a6e" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                            <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                        </svg>
                        <h3>عذراً، يجب تسجيل الدخول</h3>
                        <p>لتتمكن من إرسال ملاحظاتك أو التواصل مع فريق العمل، يرجى تسجيل الدخول إلى حسابك أولاً.</p>
                        <a href="/login" class="btn-submit" style="text-decoration: none; margin-top: 10px;">تسجيل الدخول</a>
                    </div>
                </NotAuthorized>
            </AuthorizeView>
        </div>

        <div class="feedback-image-side">
            <img id="imgfb1" src="gp images/imgfb1.png" alt="تواصل معنا" />
        </div>

    </div>

    @* قسم الكروت التعريفية *@
    <div class="feedback-features">
        <div class="feature-card">
            <img id="imgfb2" src="gp images/imgfb2.png" alt="تعليم تفاعلي" class="feature-img" />
            <h3>تعليم تفاعلي</h3>
            <p>انجاز المهام في اي وقت و في اي مكان مما يسهل العمليه التعليمية</p>
        </div>

        <div class="feature-card">
            <img id="imgfb3" src="gp images/imgfb3.png" alt="تواصل فعال" class="feature-img" />
            <h3>تواصل فعال</h3>
            <p>سهوله التواصل بين الطالب و المعلم مما يسهل العملية التعليمية</p>
        </div>
    </div>

</div>

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700&display=swap');

    :root {
        --primary: #1e3a6e;
        --primary-light: #2d5aa0;
        --accent: #4a90d9;
        --bg: #D9D9D9; 
        --card-bg: #D9D9D9;
        --input-bg: #ffffff;
        --text-main: #000000; 
        --text-muted: #333333;
        --border: #b0b0b0;
        --shadow: 0 4px 15px rgba(0,0,0,0.1);
        --radius: 10px;
    }

    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    body, .feedback-wrapper {
        font-family: 'Tajawal', sans-serif;
        background-color: var(--bg);
        color: var(--text-main);
        direction: rtl;
    }

    .feedback-wrapper {
        max-width: 1100px;
        margin: 0 auto;
        padding: 50px 20px 60px;
    }

    .feedback-top {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 40px;
        align-items: start;
        margin-bottom: 50px;
    }

    .feedback-form-side {
        display: flex;
        flex-direction: column;
        gap: 18px;
        order: 2; 
    }

    .form-group {
        margin-bottom: 15px;
        text-align: right;
    }

    .form-group label {
        display: block;
        font-size: 15px;
        font-weight: 700; 
        color: var(--text-main);
        margin-bottom: 5px;
    }

    .form-input {
        width: 100%;
        padding: 10px 14px;
        background-color: var(--input-bg);
        border: 1px solid var(--border);
        border-radius: 6px;
        font-size: 14px;
        color: #000;
        outline: none;
    }

    .btn-submit {
        display: inline-block;
        padding: 10px 32px;
        background: var(--primary);
        color: #fff;
        border: none;
        border-radius: 6px;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.3s ease;
        text-align: center;
    }

    .btn-submit:hover {
        background: var(--primary-light);
    }

    .auth-warning-box {
        background: rgba(255, 255, 255, 0.5);
        padding: 40px;
        border-radius: var(--radius);
        border: 2px dashed var(--border);
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 15px;
    }

    .auth-warning-box h3 { color: var(--primary); }
    .auth-warning-box p { color: var(--text-muted); font-size: 14px; }

    .alert-success { background: #d4edda; color: #155724; padding: 10px; border-radius: 6px; margin-top: 10px; }
    .alert-error { background: #f8d7da; color: #721c24; padding: 10px; border-radius: 6px; margin-top: 10px; }

    .feedback-image-side {
        display: flex;
        align-items: center;
        justify-content: center;
        order: 1;
    }

    .feedback-image-side img {
        width: 100%;
        border-radius: var(--radius);
    }

    .feedback-features {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 30px;
    }

    .feature-card {
        background: var(--card-bg);
        border-radius: 16px;
        padding: 30px 24px;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        gap: 12px;
        box-shadow: var(--shadow);
        border: 1px solid #c0c0c0;
    }

    .feature-img { width: 80px; margin-bottom: 10px; }

    .text-danger { color: #c82333; font-size: 12px; }

    @@media (max-width: 700px) {
        .feedback-top, .feedback-features { grid-template-columns: 1fr; }
        .feedback-image-side { order: 1; }
        .feedback-form-side { order: 2; }
    }
</style>

@code {
    private FormData formModel = new FormData();
    private string successMessage = "";
    private string errorMessage = "";
    private const string RecipientEmail = "chessplan48@gmail.com";

    private async Task HandleSubmit()
    {
        successMessage = "";
        errorMessage = "";
        try
        {
            var smtpClient = new SmtpClient("smtp.gmail.com")
            {
                Port = 587,
                Credentials = new NetworkCredential("your-email@gmail.com", "your-app-password"),
                EnableSsl = true,
            };
            
            var mailMessage = new MailMessage
            {
                From = new MailAddress("your-email@gmail.com", "نموذج التواصل"),
                Subject = $"رسالة جديدة من: {formModel.Name}",
                Body = $"الاسم: {formModel.Name}\nالهاتف: {formModel.Phone}\nالإيميل: {formModel.Email}\n\nالرسالة:\n{formModel.Message}",
                IsBodyHtml = false,
            };
            
            mailMessage.To.Add(RecipientEmail);
            await smtpClient.SendMailAsync(mailMessage);
            
            successMessage = "تم إرسال رسالتك بنجاح!";
            formModel = new FormData();
        }
        catch (Exception)
        {
            errorMessage = "حدث خطأ أثناء الإرسال. يرجى مراجعة إعدادات الخادم.";
        }
    }

    public class FormData
    {
        [Required(ErrorMessage = "الاسم مطلوب")] 
        public string Name { get; set; } = "";
        
        [Required(ErrorMessage = "رقم الهاتف مطلوب")] 
        public string Phone { get; set; } = "";
        
        [Required(ErrorMessage = "الإيميل مطلوب")]
        [EmailAddress(ErrorMessage = "صيغة البريد الإلكتروني غير صحيحة")] 
        public string Email { get; set; } = "";
        
        [Required(ErrorMessage = "الرسالة مطلوبة")] 
        public string Message { get; set; } = "";
    }
}