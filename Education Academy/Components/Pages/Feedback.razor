@page "/feedback"
@using System.Net
@using System.Net.Mail
@using System.ComponentModel.DataAnnotations

<div class="feedback-wrapper" dir="rtl">

    <div class="feedback-top">

        <div class="feedback-form-side">
            <EditForm Model="@formModel" OnValidSubmit="HandleSubmit">
                <DataAnnotationsValidator />

                <div class="form-group">
                    <label>الاسم</label>
                    <InputText @bind-Value="formModel.Name" class="form-input" />
                    <ValidationMessage For="@(() => formModel.Name)" class="text-danger" />
                </div>

                <div class="form-group">
                    <label>رقم الهاتف</label>
                    <InputText @bind-Value="formModel.Phone" class="form-input" type="tel" />
                    <ValidationMessage For="@(() => formModel.Phone)" class="text-danger" />
                </div>

                <div class="form-group">
                    <label>البريد الالكتروني</label>
                    <InputText @bind-Value="formModel.Email" class="form-input" type="email" />
                    <ValidationMessage For="@(() => formModel.Email)" class="text-danger" />
                </div>

                <div class="form-group">
                    <label>الرساله</label>
                    <InputTextArea @bind-Value="formModel.Message" class="form-input form-textarea" rows="5" />
                    <ValidationMessage For="@(() => formModel.Message)" class="text-danger" />
                </div>

                <button type="submit" class="btn-submit">إرسال</button>

                @if (!string.IsNullOrEmpty(successMessage))
                {
                    <div class="alert-success">@successMessage</div>
                }
                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert-error">@errorMessage</div>
                }
            </EditForm>
        </div>

        <div class="feedback-image-side">
            <img id="imgfb1" src="gp images/imgfb1.png" alt="تواصل معنا" />
        </div>

    </div>

    @* الكروت *@
    <div class="feedback-features">
        @*الاول*@
        <div class="feature-card">
            <img id="imgfb2" src="gp images/imgfb2.png" alt="تعليم تفاعلي" class="feature-img" />
            <h3>تعليم تفاعلي</h3>
            <p>انجاز المهام في اي وقت و في اي مكان مما يسهل العمليه التعليمية</p>
        </div>

        @*التاني*@
        <div class="feature-card">
            <img id="imgfb3" src="gp images/imgfb3.png" alt="تواصل فعال" class="feature-img" />
            <h3>تواصل فعال</h3>
            <p>سهوله التواصل بين الطالب و المعلم مما يسهل الغمليه التعليمية</p>
        </div>

    </div>

</div>

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700&display=swap');

    :root {
        --primary: #1e3a6e;
        --primary-light: #2d5aa0;
        --accent: #4a90d9;
        --bg: #D9D9D9; 
        --card-bg: #D9D9D9; 
        --input-bg: #ffffff;
        --text-main: #000000; 
        --text-muted: #333333;
        --border: #b0b0b0;
        --shadow: 0 4px 15px rgba(0,0,0,0.1);
        --radius: 10px;
    }

    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    body, .feedback-wrapper {
        font-family: 'Tajawal', sans-serif;
        background-color: var(--bg);
        color: var(--text-main);
        direction: rtl;
    }

    .feedback-wrapper {
        max-width: 1100px;
        margin: 0 auto;
        padding: 50px 20px 60px;
        direction: rtl;
    }

    .feedback-top {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 40px;
        align-items: start;
        margin-bottom: 50px;
        direction: rtl;
    }

    /* الفورم */
    .feedback-form-side {
        display: flex;
        flex-direction: column;
        gap: 18px;
        order: 2; 
    }

    .form-group label {
        font-size: 15px;
        font-weight: 700; 
        color: var(--text-main);
        text-align: right;
    }

    .form-input {
        width: 100%;
        padding: 10px 14px;
        background-color: var(--input-bg);
        border: 1px solid var(--border);
        border-radius: 6px;
        font-size: 14px;
        color: #000;
        outline: none;
    }

    .btn-submit {
        align-self: flex-end;
        padding: 10px 32px;
        background: var(--primary);
        color: #fff;
        border: none;
        border-radius: 6px;
        font-weight: 600;
        cursor: pointer;
    }

    /* الصورة */
    .feedback-image-side {
        border: 2px solid var(--primary);
        border-radius: var(--radius);
        overflow: hidden;
        background: var(--bg);
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 280px;
        order: 1;
    }

        .feedback-image-side img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    /* الكروت */
    .feedback-features {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 30px;
    }

    .feature-card {
        background: var(--card-bg);
        border-radius: 16px;
        padding: 30px 24px;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        gap: 12px;
        box-shadow: var(--shadow);
        border: 1px solid #c0c0c0; /* إطار خفيف لتمييز الكارت */
    }

        .feature-card h3 {
            color: var(--text-main);
            font-weight: 700;
        }

        .feature-card p {
            color: var(--text-main);
            font-size: 13.5px;
            line-height: 1.7;
        }

    .text-danger {
        color: #c82333;
        font-size: 12px;
    }

    @@media (max-width: 700px) {
        .feedback-top, .feedback-features {
            grid-template-columns: 1fr;
        }

        .feedback-image-side {
            order: 1;
        }

        .feedback-form-side {
            order: 2;
        }
    }
</style>

@code {
    private FormData formModel = new FormData();
    private string successMessage = "";
    private string errorMessage = "";
    private const string RecipientEmail = "chessplan48@gmail.com";

    private async Task HandleSubmit()
    {
        successMessage = "";
        errorMessage = "";
        try
        {
            var smtpClient = new SmtpClient("smtp.gmail.com")
            {
                Port = 587,
                Credentials = new NetworkCredential("your-email@gmail.com", "your-app-password"),
                EnableSsl = true,
            };
            var mailMessage = new MailMessage
            {
                From = new MailAddress("your-email@gmail.com", "نموذج التواصل"),
                Subject = $"رسالة جديدة من: {formModel.Name}",
                Body = $"الاسم: {formModel.Name}\nالهاتف: {formModel.Phone}\nالإيميل: {formModel.Email}\n\nالرسالة:\n{formModel.Message}",
                IsBodyHtml = false,
            };
            mailMessage.To.Add(RecipientEmail);
            await smtpClient.SendMailAsync(mailMessage);
            successMessage = "تم إرسال رسالتك بنجاح!";
            formModel = new FormData();
        }
        catch (Exception)
        {
            errorMessage = "حدث خطأ أثناء الإرسال.";
        }
    }

    public class FormData
    {
        [Required(ErrorMessage = "الاسم مطلوب")] public string Name { get; set; } = "";
        [Required(ErrorMessage = "رقم الهاتف مطلوب")] public string Phone { get; set; } = "";
        [Required(ErrorMessage = "الإيميل مطلوب")][EmailAddress] public string Email { get; set; } = "";
        [Required(ErrorMessage = "الرسالة مطلوبة")] public string Message { get; set; } = "";
    }
}