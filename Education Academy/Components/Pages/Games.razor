@page "/games"
@using EducationAcademy.Models
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.Extensions.DependencyInjection
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Nav
@inject EducationAcademy.Services.IProgressionService ProgressionService
@inject IServiceScopeFactory ServiceScopeFactory

<div class="games-zone-container">
    <div class="text-center mb-5">
        <h2 class="display-4 fw-bold text-primary">منطقة الألعاب التعليمية</h2>
        <p class="text-muted">تعلم بطريقة ممتعة واجمع النقاط لفتح المزيد!</p>
    </div>

    <div class="games-grid">
        @* الصف الأول *@
        @renderGameCard("المتاهة", "اهلا بك في المغارة العجيبة، اجمع الكنز للعودة للمنزل", 200, "fas fa-code", "/game/codecombat")
        @renderGameCard("FG", "لعبة قتالية حيث الأعداء هم أكواد برمجية خاطئة", 300, "fas fa-plus-circle", "/game/fgmadd")
        @renderGameCard("تصليح الطرق", "لعبة سيارات حيث مهمتك تفادي الأعداء وتصليح الأخطاء", 400, "fas fa-car-side", "/game/roadrad")

        @* الصف الثاني*@
        @renderGameCard("بداية المبرمج", "احذر و لا تجعل الكره تسقط", 30, "fas fa-ball", "https://scratch.mit.edu/projects/10128515/editor/")
        @renderGameCard("تحرك في الفضاء", "اصلح حركات لتجمع نقاط اكثر", 60, "fas fa-star", "https://scratch.mit.edu/projects/394877180/editor/")
        @renderGameCard("بينج بونج", "تعلم كيف تصنع الاعاب لتتالق", 100, "fas fa-lightbulb", "https://scratch.mit.edu/projects/935757174/editor/")
    </div>
</div>

@code {
    private int userXP = 0; 
    private bool isAdmin = false;
    private bool isLoaded = false;

    protected override async Task OnInitializedAsync() 
    {
        var authState = await AuthProvider.GetAuthenticationStateAsync();
    var userPrincipal = authState.User; 

        if (userPrincipal.Identity != null && userPrincipal.Identity.IsAuthenticated) 
        {
            isAdmin = userPrincipal.IsInRole("Admin"); 
    var userId = userPrincipal.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value; 

            if (!string.IsNullOrEmpty(userId)) 
            {
                userXP = await ProgressionService.GetUserXPAsync(userId);
}
        }
        isLoaded = true; 
    }

    private bool IsGameLocked(int requiredXP) 
{
    if (isAdmin) return false; 
        return userXP < requiredXP; 
    }

private RenderFragment renderGameCard(string title, string description, int requiredXP, string iconClass, string url) 
{
    bool isLocked = IsGameLocked(requiredXP); 
        return __builder =>
        {
            <div class="game-card @(isLocked ? "locked" : "unlocked")" @onclick="() => NavigateToGame(url, isLocked)">
                <div class="card-content">
                    @if (isLocked)
        {
        <div class="lock-badge">🔒 مطلوب @requiredXP XP</div> 
        }
        <div class="icon-box">
            <i class="@iconClass"></i>
        </div>
        <h3>@title</h3> 
        <p>@description</p> 
        <div class="level-badge">@(requiredXP) XP</div> 
    </div>
</div>
        };
}

private void NavigateToGame(string url, bool isLocked) 
{
    if (!isLocked) 
        {
        if (url.StartsWith("http"))
        {
            Nav.NavigateTo(url, forceLoad: true);
        }
        else
        {
            Nav.NavigateTo(url); 
            }
    }
}
}

<style>
    .games-zone-container {
        padding: 60px 10%;
        background: #f8fafc;
        min-height: 100vh;
        direction: rtl;
    }

    .games-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 0px 30px;
        margin-top: 40px;
    }

    .game-card {
        transition: transform 0.3s ease;
         position: relative;
    }

    .card-content {
        background: white;
        border-radius: 0px; 
        padding: 40px 20px;
        text-align: center;
        border: 1px solid #e2e8f0;
        cursor: pointer;
        height: 100%;
    }

    .game-card.unlocked:hover {
        transform: scale(1.02); 
        z-index: 10;
    }

    .game-card.locked {
        filter: grayscale(0.8);
         cursor: not-allowed;
    }

    .level-badge {
        position: absolute;
         top: 10px;
         right: 10px;
         background: #4b7983;
         color: white;
         padding: 2px 10px;
         border-radius: 20px;
         font-size: 0.7rem;
        }

    .lock-badge {
        position: absolute;
        top: 10px;
        left: 10px;
        background: #ef4444;
        color: white;
        padding: 2px 8px;
        border-radius: 5px;
        font-size: 0.7rem;
    }

    .icon-box {
        font-size: 2.5rem;
        margin-bottom: 15px;
        color: #4b7983;
    }

    h3 {
        color: #1e293b;
         font-size: 1.2rem;
        margin-bottom: 8px;
    }

    p {
        color: #64748b;
         font-size: 0.85rem;
    }
</style>