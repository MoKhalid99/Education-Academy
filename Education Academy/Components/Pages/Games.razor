@page "/games"
@using EducationAcademy.Models
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.Extensions.DependencyInjection
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Nav
@inject EducationAcademy.Services.IProgressionService ProgressionService
@inject IServiceScopeFactory ServiceScopeFactory

<div class="games-zone-container">
    <div class="text-center mb-5">
        <h2 class="display-4 fw-bold text-primary">منطقة الألعاب التعليمية</h2>
        <p class="text-muted">تعلم بطريقة ممتعة واجمع النقاط لفتح المزيد!</p>
    </div>

    <div class="games-grid">
        @* اللعبة الأولى: تتطلب 200 *@
        @renderGameCard("المتاهة", "اهلا بك في المغارة العجيبة، اجمع الكنز للعودة للمنزل", 200, "fas fa-code", "/game/codecombat")

        @* اللعبة الثانية: تتطلب 300 *@
        @renderGameCard("FG", "لعبة قتالية حيث الأعداء هم أكواد برمجية خاطئة", 300, "fas fa-plus-circle", "/game/fgmadd")

        @* اللعبة الثالثة: تتطلب 400 *@
        @renderGameCard("تصليح الطرق", "لعبة سيارات حيث مهمتك تفادي الأعداء وتصليح الأخطاء", 400, "fas fa-car-side", "/game/roadrad")
    </div>
</div>

@code {
    private int userXP = 0; // سنستخدم الـ XP الآن
    private bool isAdmin = false;
    private bool isLoaded = false;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthProvider.GetAuthenticationStateAsync();
        var userPrincipal = authState.User;

        if (userPrincipal.Identity != null && userPrincipal.Identity.IsAuthenticated)
        {
            isAdmin = userPrincipal.IsInRole("Admin");
            var userId = userPrincipal.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

            if (!string.IsNullOrEmpty(userId))
            {
                // جلب نقاط الـ XP الحقيقية من قاعدة البيانات مباشرة عبر الخدمة
                userXP = await ProgressionService.GetUserXPAsync(userId);
            }
        }
        isLoaded = true;
    }

    private bool IsGameLocked(int requiredXP)
    {
        // الأدمن تفتح له كل الألعاب
        if (isAdmin) return false;

        //  إذا كانت نقاط الطالب أقل من النقاط المطلوبة، تظل اللعبة مغلقة
        return userXP < requiredXP;
    }

    private RenderFragment renderGameCard(string title, string description, int requiredXP, string iconClass, string url)
    {
        bool isLocked = IsGameLocked(requiredXP);

        return __builder =>
        {
            <div class="game-card @(isLocked ? "locked" : "unlocked")" @onclick="() => NavigateToGame(url, isLocked)">
                <div class="card-content">
                    @if (isLocked)
                    {
                        <div class="lock-badge">🔒 مطلوب @requiredXP XP لفتح اللعبة</div>
                    }
                    <div class="icon-box">
                        <i class="@iconClass"></i>
                    </div>
                    <h3>@title</h3>
                    <p>@description</p>
                    <div class="level-badge">@(requiredXP) XP</div>
                </div>
            </div>
        };
    }

    private void NavigateToGame(string url, bool isLocked)
    {
        if (!isLocked)
        {
            Nav.NavigateTo(url);
        }
    }
}

<style>
    .games-zone-container {
        padding: 60px 10%;
        background: #f8fafc;
        min-height: 100vh;
        direction: rtl;
    }

    .games-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 30px;
        margin-top: 40px;
    }

    .game-card {
        transition: transform 0.3s ease, filter 0.3s ease;
        position: relative;
    }

    .card-content {
        background: white;
        border-radius: 20px;
        padding: 40px 20px;
        text-align: center;
        border: 2px solid transparent;
        cursor: pointer;
    }

    .game-card.unlocked:hover {
        transform: translateY(-10px);
    }

        .game-card.unlocked:hover .card-content {
            border-color: #4b7983;
        }

    .game-card.locked {
        filter: grayscale(0.8);
        cursor: not-allowed;
    }

    .level-badge {
        position: absolute;
        top: 20px;
        right: 20px;
        background: #4b7983;
        color: white;
        padding: 5px 15px;
        border-radius: 50px;
        font-size: 0.8rem;
    }

    .icon-box {
        font-size: 3rem;
        margin-bottom: 20px;
        color: #4b7983;
    }

    .game-icon {
        color: #4b7983;
    }

    .lock-icon {
        color: #94a3b8;
    }

    .status-btn {
        margin-top: 20px;
        padding: 10px 30px;
        border-radius: 10px;
        font-weight: bold;
        display: inline-block;
    }

    .play-btn {
        background: #4b7983;
        color: white;
    }

    .locked-btn {
        background: #e2e8f0;
        color: #64748b;
    }

    h3 {
        color: #1e293b;
        margin-bottom: 10px;
    }

    p {
        color: #64748b;
        font-size: 0.9rem;
    }
</style>